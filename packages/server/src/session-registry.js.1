'use strict';

/**
 * session-registry.js
 * Live session tracking for SynthDoor.
 *
 * Maintains an in-memory map of all currently connected sessions. Each
 * session entry tracks who is connected, on what transport, where they
 * are (menu or a specific game), and when they connected. A disconnect
 * handle is stored for kick support.
 *
 * Liveness model
 * ──────────────
 * The registry depends on transports calling remove(id) when a session
 * ends. In ordinary disconnects (clean FIN, idle timeout, kick) that's
 * what happens. But half-open TCP, abruptly-killed WebSockets, NAT box
 * dropouts, and uncaught exceptions in route() can all leave entries
 * stranded — the disconnect callback never fires and the row sits in
 * Who's Online forever.
 *
 * To deal with that:
 *
 *   1. ping(id)
 *      Every session has a lastSeenAt timestamp that the transport
 *      bumps on activity (incoming bytes, navigation, user keypress).
 *
 *   2. isLive callback
 *      At registration the transport supplies a zero-arg function that
 *      returns true if the underlying socket is still live (e.g.
 *      `() => !socket.destroyed`). The sweep calls it on every entry.
 *
 *   3. Periodic sweep
 *      A setInterval-driven pass evicts entries whose isLive() returns
 *      false, OR whose lastSeenAt is older than STALE_AFTER_MS. Either
 *      condition catches the cases the disconnect handler missed.
 *
 *   4. Read-time filter
 *      list() applies the same checks before returning, so even between
 *      sweeps stale rows never appear in Who's Online.
 *
 * Transports that don't supply isLive (e.g. tests) get the time-based
 * cutoff only — still safer than the previous "never expire" behaviour.
 */

const { randomBytes } = require('crypto');

// Session is considered stale if no activity for this long. Tuned to be
// well above any normal in-game idle gap (a player thinking about a move
// is fine) but low enough that ghosts disappear from Who's Online within
// a few minutes.
//
// The sweep below pings live sessions every 60s, so a real connection
// can never be reaped by accident — it would have to fall completely
// silent for 5 minutes, which a healthy TCP socket does not.
const STALE_AFTER_MS = 5 * 60 * 1000;

// How often the background sweep runs.
const SWEEP_INTERVAL_MS = 30 * 1000;

class SessionRegistry {
  /**
   * @param {object} [opts]
   * @param {number} [opts.staleAfterMs]    Activity gap before eviction (default 5 min)
   * @param {number} [opts.sweepIntervalMs] Sweep cadence (default 30 s)
   * @param {{warn:Function,info:Function}} [opts.logger]
   */
  constructor(opts = {}) {
    this._sessions       = new Map();
    this._staleAfterMs   = opts.staleAfterMs   || STALE_AFTER_MS;
    this._sweepIntervalMs = opts.sweepIntervalMs || SWEEP_INTERVAL_MS;
    this._logger         = opts.logger || null;

    // Start a background sweep. Allowed to keep the process alive — the
    // server's shutdown() calls stop().
    this._sweepTimer = setInterval(() => this._sweep(), this._sweepIntervalMs);
    // unref() so that on graceful shutdown the timer doesn't keep node
    // running if everything else has stopped.
    if (this._sweepTimer.unref) this._sweepTimer.unref();
  }

  // ─── Public API ────────────────────────────────────────────────────────────

  /**
   * Register a new session. Returns a unique session ID.
   *
   * @param {object}   opts
   * @param {string}   opts.username    Authenticated or naive username
   * @param {string}   opts.transport   'telnet' | 'rlogin' | 'web'
   * @param {string}   opts.ipAddress   Remote IP (may be null)
   * @param {Function} opts.disconnect  Callable that terminates the connection
   * @param {Function} [opts.isLive]    Optional zero-arg liveness probe.
   *                                    Return true if the socket is still
   *                                    connected. If omitted, only the
   *                                    activity timeout applies.
   * @returns {string}  Session ID
   */
  add({ username, transport, ipAddress, disconnect, isLive }) {
    const id  = randomBytes(8).toString('hex');
    const now = Date.now();
    this._sessions.set(id, {
      id,
      username:    username || 'unknown',
      transport:   transport || 'unknown',
      ipAddress:   ipAddress || null,
      location:    'menu',           // 'menu' or a game name
      connectedAt: now,
      lastSeenAt:  now,
      gameEnteredAt: null,
      disconnect:  disconnect || (() => {}),
      isLive:      typeof isLive === 'function' ? isLive : null,
    });
    return id;
  }

  /**
   * Bump the activity timestamp for a session. Call from transports on any
   * user-driven event (incoming bytes, keypress, screen redraw triggered
   * by user input). Cheap — just an O(1) Map lookup and a write.
   *
   * @param {string} id
   */
  ping(id) {
    const entry = this._sessions.get(id);
    if (entry) entry.lastSeenAt = Date.now();
  }

  /**
   * Update the location of a session. Implicitly pings.
   *
   * @param {string} id
   * @param {string} location  'menu' | game name
   */
  setLocation(id, location) {
    const entry = this._sessions.get(id);
    if (!entry) return;
    entry.location      = location;
    entry.gameEnteredAt = location !== 'menu' ? Date.now() : null;
    entry.lastSeenAt    = Date.now();
  }

  /**
   * Remove a session (call on disconnect).
   * @param {string} id
   */
  remove(id) {
    this._sessions.delete(id);
  }

  /**
   * Return a snapshot of all currently-live sessions.
   *
   * The list is filtered as a side effect: any entry whose isLive() is
   * false, or whose lastSeenAt has aged past staleAfterMs, is evicted
   * before the snapshot is built. This means stale rows never appear in
   * Who's Online even if the periodic sweep hasn't fired yet.
   *
   * @returns {SessionSnapshot[]}
   */
  list() {
    this._evictStale();
    const now = Date.now();
    return Array.from(this._sessions.values()).map(e => ({
      id:           e.id,
      username:     e.username,
      transport:    e.transport,
      ipAddress:    e.ipAddress,
      location:     e.location,
      connectedAt:  e.connectedAt,
      connectedSec: Math.floor((now - e.connectedAt) / 1000),
      gameEnteredAt: e.gameEnteredAt,
      gameSec:      e.gameEnteredAt ? Math.floor((now - e.gameEnteredAt) / 1000) : null,
      lastSeenAt:   e.lastSeenAt,
      idleSec:      Math.floor((now - e.lastSeenAt) / 1000),
    }));
  }

  /**
   * Number of live sessions (after stale-eviction).
   * @returns {number}
   */
  count() {
    this._evictStale();
    return this._sessions.size;
  }

  /**
   * Kick a session by ID (forcibly disconnect).
   * @param {string} id
   * @returns {boolean}  true if found and disconnect was attempted
   */
  kick(id) {
    const entry = this._sessions.get(id);
    if (!entry) return false;
    try { entry.disconnect(); } catch (_) {}
    this._sessions.delete(id);
    return true;
  }

  /**
   * Single-session snapshot, or null.
   * @param {string} id
   */
  get(id) {
    return this.list().find(s => s.id === id) || null;
  }

  /**
   * Stop the background sweep timer. Called from server shutdown.
   */
  stop() {
    if (this._sweepTimer) {
      clearInterval(this._sweepTimer);
      this._sweepTimer = null;
    }
  }

  // ─── Internal ────────────────────────────────────────────────────────────

  _evictStale() {
    const cutoff = Date.now() - this._staleAfterMs;
    const dead   = [];

    for (const entry of this._sessions.values()) {
      // Liveness probe wins — if the socket says it's gone, it's gone,
      // regardless of how recent lastSeenAt is.
      if (entry.isLive) {
        let live;
        try { live = entry.isLive(); } catch (_) { live = false; }
        if (!live) { dead.push(entry); continue; }
      }
      if (entry.lastSeenAt < cutoff) {
        dead.push(entry);
      }
    }

    for (const entry of dead) {
      this._sessions.delete(entry.id);
      // Best effort: if there is a disconnect callback, invoke it so any
      // remaining server-side resources get cleaned up too. Wrapped in
      // try/catch because the callback's transport may already have torn
      // down its own state (e.g. socket.destroyed).
      try { entry.disconnect(); } catch (_) {}
      if (this._logger) {
        this._logger.info(`[SessionRegistry] reaped stale session id=${entry.id} username=${entry.username} transport=${entry.transport}`);
      }
    }

    return dead.length;
  }

  /**
   * Background sweep — runs on the timer.
   */
  _sweep() {
    try {
      this._evictStale();
    } catch (err) {
      if (this._logger && this._logger.warn) {
        this._logger.warn(`[SessionRegistry] sweep error: ${err.message}`);
      }
    }
  }
}

module.exports = SessionRegistry;
