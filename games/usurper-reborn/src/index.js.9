'use strict';
const path = require('path');
const net = require('net');
const { StringDecoder } = require('string_decoder');

// CRITICAL: Always use path.join for engine imports
const { GameBase, Screen, Color } = require(
  path.join(__dirname, '..', '..', '..', 'packages', 'engine', 'src', 'index.js')
);

// --- HARDCODED CONNECTION CONFIGURATION ---
const REMOTE_HOST = 'play.usurper-reborn.net';
const REMOTE_PORT = 4000;

// Configurable timeframe (in ms) to buffer lines for predictive pagination reduction
const SMART_PAGINATION_BUFFER_MS = 250;

// Standard CP437 mapping for high ASCII (128 to 255)
const CP437_HIGH = "ÇüéâäàåçêëèïîìÄÅÉæÆôöòûùÿÖÜ¢£¥₧ƒáíóúñÑªº¿⌐¬½¼¡«»░▒▓│┤╡╢╖╕╣║╗╝╜╛┐└┴┬├─┼╞╟╚╔╩╦╠═╬╧╨╤╥╙╘╒╓╫╪┘┌█▄▌▐▀αßΓπΣσµτΦΘΩδ∞φε∩≡±≥≤⌠⌡÷≈°∙·√ⁿ²■ ";

// Build a reverse map: Unicode Character -> Raw CP437 binary string byte
const UNICODE_TO_CP437 = {};
for (let i = 0; i < CP437_HIGH.length; i++) {
  UNICODE_TO_CP437[CP437_HIGH[i]] = String.fromCharCode(i + 128);
}

// --- SUBSTANTIAL UNICODE FALLBACKS FOR MUDs ---
const FALLBACKS = {
  // Typography
  '‘': "'", '’': "'", '‚': "'", '‛': "'",
  '“': '"', '”': '"', '„': '"', '‟': '"',
  '–': '-', '—': '--', '…': '...',
  
  // Bullets and blocks
  '•': '*', '◦': 'o', '▪': '*', '▫': 'o', '►': '>', '◄': '<',
  '■': '\xFE', // CP437 solid square
  '□': '[ ]', '▣': '[x]',
  
  // Arrows
  '←': '<-', '↑': '^', '→': '->', '↓': 'v',
  '↔': '<->', '↕': '^v',
  '⇐': '<=', '⇑': '^', '⇒': '=>', '⇓': 'v', '⇔': '<=>',
  
  // Math & Misc Symbols
  '±': '+/-', '×': 'x', '÷': '/', '≈': '~', '≠': '!=',
  '©': '(c)', '®': '(r)', '™': '(tm)',
  '✓': 'v', '✗': 'x'
};
Object.assign(UNICODE_TO_CP437, FALLBACKS);

/**
 * Reconstructs the original line with ANSI sequences preserved, omitting the removed indices.
 */
function buildResult(originalLine, charsArray) {
  const removedSet = new Set();
  for (let i = 0; i < charsArray.length; i++) {
    if (charsArray[i].isRemoved) removedSet.add(charsArray[i].origIdx);
  }
  
  const map = [];
  const ansiRegex = /\x1b\[[0-9;]*[a-zA-Z]/g;
  let lastIdx = 0;
  let match;
  
  while ((match = ansiRegex.exec(originalLine)) !== null) {
    const textChunk = originalLine.substring(lastIdx, match.index);
    for (let i = 0; i < textChunk.length; i++) {
      if (textChunk[i] !== '\r' && textChunk[i] !== '\n') {
        map.push(lastIdx + i);
      }
    }
    lastIdx = match.index + match[0].length;
  }
  const tailChunk = originalLine.substring(lastIdx);
  for (let i = 0; i < tailChunk.length; i++) {
    if (tailChunk[i] !== '\r' && tailChunk[i] !== '\n') {
      map.push(lastIdx + i);
    }
  }
  
  const originalIndicesToRemove = new Set();
  for (let origIdx of removedSet) {
    if (map[origIdx] !== undefined) {
      originalIndicesToRemove.add(map[origIdx]);
    }
  }
  
  let newLine = '';
  for (let i = 0; i < originalLine.length; i++) {
    if (!originalIndicesToRemove.has(i)) {
      newLine += originalLine[i];
    }
  }
  
  let newPlainText = '';
  for (let i = 0; i < charsArray.length; i++) {
    if (!charsArray[i].isRemoved) {
      newPlainText += charsArray[i].c;
    }
  }
  
  return { line: newLine, plainText: newPlainText };
}

/**
 * Multi-Tiered Intelligent Squashing Strategy
 * Prioritizes retaining the visual structure of MUD tables.
 */
function applySquashing(originalLine, plainText, prevPlainText) {
  if (plainText.length <= 80) return null;

  let r = plainText.length - 80;
  
  const chars = plainText.split('').map((c, i) => ({
    c: c,
    origIdx: i,
    isSpace: c === ' ',
    isRemoved: false
  }));

  // Map out the column boundaries of the text on the line directly above us
  const prevWordStarts = new Set();
  let inPrevWord = false;
  for (let i = 0; i < prevPlainText.length; i++) {
    if (prevPlainText[i] !== ' ') {
      if (!inPrevWord) {
        prevWordStarts.add(i);
        inPrevWord = true;
      }
    } else {
      inPrevWord = false;
    }
  }

  // --- TIER 1: Trailing Whitespace ---
  for (let i = chars.length - 1; i >= 0 && r > 0; i--) {
    if (chars[i].isSpace) {
      chars[i].isRemoved = true;
      r--;
    } else {
      break;
    }
  }
  if (r <= 0) return buildResult(originalLine, chars);

  // Helper function to extract currently active, squashable blocks of spaces
  function getSpaceGroupsAndWords() {
    let groups = [];
    let currentIndices = [];
    let visualPos = 0;
    let foundText = false;
    
    for (let i = 0; i < chars.length; i++) {
      if (chars[i].isRemoved) continue;
      
      if (chars[i].isSpace) {
        currentIndices.push(i);
      } else {
        if (currentIndices.length > 0) {
          groups.push({
            indices: currentIndices,
            nextWordCol: visualPos, // Visual column of the word immediately after this gap
            isLeading: !foundText
          });
          currentIndices = [];
        }
        foundText = true;
      }
      visualPos++;
    }

    if (currentIndices.length > 0) {
      groups.push({
        indices: currentIndices,
        nextWordCol: visualPos, 
        isLeading: !foundText
      });
    }
    
    // We only want internal groups with > 1 space so we don't merge words together.
    // However, the leading whitespace group is safe to reduce to 0.
    return groups.filter(g => g.indices.length > 1 || g.isLeading);
  }

  // --- TIER 2: Safe and Unsafe Internal/Leading Whitespace ---
  while (r > 0) {
    let groups = getSpaceGroupsAndWords();
    if (groups.length === 0) break;

    let bestGroup = null;
    let bestScore = -Infinity;

    for (let g of groups) {
      // Check if shrinking this gap shifts the next word OUT of or INTO alignment
      let breaksAlignment = prevWordStarts.has(g.nextWordCol);
      let createsAlignment = prevWordStarts.has(g.nextWordCol - 1);
      
      let score = g.indices.length; 
      
      // Give leading whitespace a massive priority bonus UNLESS it would break table alignment
      if (g.isLeading && !breaksAlignment) {
        score += 100;
      }

      if (breaksAlignment) score -= 1000;
      if (createsAlignment) score += 500;

      if (score > bestScore) {
        bestScore = score;
        bestGroup = g;
      }
    }

    // Squash 1 space from the end of the highest scoring block
    chars[bestGroup.indices[bestGroup.indices.length - 1]].isRemoved = true;
    r--;
  }
  if (r <= 0) return buildResult(originalLine, chars);

  // --- TIER 3: Second-Tier Rule (Non-Whitespace / Safe Punctuation) ---
  // Only runs if all space gaps are minimized to 1 cell and we're STILL > 80 chars
  const isSquashablePunc = (c) => c === '-' || c === '.' || c === '=' || c === '_' || c === '*' || c === '~';
  while (r > 0) {
    let squashedAny = false;
    for (let i = 1; i < chars.length; i++) {
      if (chars[i].isRemoved) continue;
      
      let prevIdx = i - 1;
      while (prevIdx >= 0 && chars[prevIdx].isRemoved) prevIdx--;
      
      // Squash repetitive punctuation (e.g. '--' to '-', '...' to '..')
      if (prevIdx >= 0) {
        if (chars[i].c === chars[prevIdx].c && isSquashablePunc(chars[i].c)) {
          chars[i].isRemoved = true;
          r--;
          squashedAny = true;
          if (r <= 0) break;
        }
      }
    }
    if (!squashedAny) break; // Out of safe punctuation targets
  }
  
  // If we STILL couldn't reduce the line to <= 80 characters using safe methods,
  // we abort entirely and let it wrap normally, per Rule 1.
  if (r > 0) {
    return null;
  }

  return buildResult(originalLine, chars);
}

class UsurperReborn extends GameBase {
  static get GAME_NAME() { return 'usurper-reborn'; }
  static get GAME_TITLE() { return 'Usurper Reborn'; }

  async run() {
    this.screen.setMode(Screen.SCROLL);
    this.terminal.clearScreen();
    
    await this._connectToServer();

    this.terminal.setColor(Color.BRIGHT_WHITE, Color.BLACK);
    this.terminal.println('\nExiting Usurper Reborn...');
    this.terminal.resetAttrs();
  }

  /**
   * Main Telnet client loop.
   */
  _connectToServer() {
    return new Promise((resolve) => {
      let isResolved = false;
      let connected = false;
      let iacState = 0; 
      
      let echoLocally = true;
      let recentTextBuffer = '';
      
      // Stream Processing State
      let lineBuffer = '';
      let promptTimeout = null;
      let burstTimer = null;

      // When the 50ms prompt timer flushes a partial line (no trailing \n),
      // its bytes are written to the terminal as a prompt and the cursor
      // sits mid-row. If the rest of that line then arrives in a later TCP
      // chunk, the bytes up to the next \n are the visual continuation of
      // that prompt, not a fresh new line. We track the stripped-plain
      // prefix so the continuation can be (a) written raw to the terminal
      // to complete the visible row, (b) merged with the prefix to update
      // `prevPlainText` correctly for downstream squashing, and (c) counted
      // as a single printed line for pagination — without going through
      // queueLine, which would otherwise treat it as a fresh row and poison
      // the alignment anchor with a meaningless tail fragment like "4  ".
      let pendingPromptFragment = null; // string | null, ANSI-stripped prefix

      // Box-drawing alignment repair: some servers send box content rows
      // that are shorter than their surrounding border rows (the closing
      // ║ ends up visually shifted left of the matching ╗/╣/╝). We track
      // the right-edge column for each active box, keyed by the left-edge
      // column of the box, so multiple concurrent boxes (e.g. an outer
      // menu plus an inner notice) can be repaired independently.
      // After CP437 mapping the box-drawing chars are single-byte: the
      // left-edge corners are É/Ì/È, the right-edge corners are »/¹/¼,
      // the vertical bar is º, and the horizontal dash is Í. The unicode
      // names stay in the comments for readability.
      // Map<leftCol:number, rightCol:number>
      const boxRightEdges = new Map();
      const BOX_LEFT_CHARS = '\xC9\xCC\xC8\xCB\xCA\xD6\xC7\xD3'; // ╔ ╠ ╚ ╦ ╩ ╓ ╟ ╙ etc.
      const BOX_RIGHT_CHARS = '\xBB\xB9\xBC\xCB\xCA\xB7\xB6\xBD'; // ╗ ╣ ╝ ╦ ╩ etc.
      const BOX_DASH = '\xCD'; // ═
      const BOX_BAR = '\xBA';  // ║
      
      let linesPrinted = 0;
      let isPaused = false;
      let lastWasEmptyLine = false;
      let cursorAtStartOfLine = true;
      let prevPlainText = '';

      // Pagination Lock States
      let allowPagination = false;
      let seenPaginationUnlock = false;

      let queueTimer = null;
      let lineBufferQueue = [];

      const utf8Decoder = new StringDecoder('utf8');

      this.terminal.clearScreen();
      this.terminal.setColor(Color.BRIGHT_CYAN, Color.BLACK);
      this.terminal.println(`Connecting to ${REMOTE_HOST}:${REMOTE_PORT}...`);
      this.terminal.println(`(Press Ctrl+] to forcefully disconnect at any time)`);
      this.terminal.println();
      this.terminal.println(`Compact mode is recommended with this client.`);
      this.terminal.println();
      this.terminal.resetAttrs();

      const socket = net.createConnection(REMOTE_PORT, REMOTE_HOST);

      const cleanup = () => {
        if (isResolved) return;
        isResolved = true;
        clearTimeout(promptTimeout);
        clearTimeout(burstTimer);
        clearTimeout(queueTimer);
        this.terminal.removeListener('key', keyHandler);
        if (!socket.destroyed) socket.destroy();
        resolve();
      };

      socket.on('connect', () => { connected = true; });

      // --- PREDICTIVE PAGINATION PROCESSOR ---
      const flushQueue = () => {
        queueTimer = null;
        if (isPaused) return;

        // 1. Initial compaction & Structural Protection
        let vLastEmpty = lastWasEmptyLine;
        let vCursorStart = cursorAtStartOfLine;
        
        for (let i = 0; i < lineBufferQueue.length; i++) {
            let item = lineBufferQueue[i];
            
            if (item.isClearScreen) {
                vCursorStart = true;
            }

            // A newline is PROTECTED if dropping it would cause text to append horizontally onto a prompt
            item.isProtectedNewline = false;
            if (item.isJustNewline && !vCursorStart) {
                item.isProtectedNewline = true;
            }

            if (item.isJustNewline) {
                if (vLastEmpty && !item.isProtectedNewline) {
                    lineBufferQueue.splice(i, 1);
                    i--;
                    continue;
                }
                vLastEmpty = true;
            } else {
                vLastEmpty = false;
            }

            if (item.hasNewline) vCursorStart = true;
            else vCursorStart = false;
        }

        // 2. Intelligent Pagination Squeeze
        // See if emitting the entire spooled block will trigger pagination
        let vLines = linesPrinted;
        let vAllow = allowPagination;
        let triggersPagination = false;
        
        for (let item of lineBufferQueue) {
            if (item.unlocksPagination) {
                vAllow = true;
                vLines = 0;
            }
            if (item.isClearScreen) vLines = 0;
            if (!item.isPrompt && item.hasNewline) {
                vLines++;
                if (vAllow && vLines >= 25) triggersPagination = true;
            }
        }

        if (triggersPagination) {
            // We have a pagination event incoming. Actively drop empty lines from the spool to squeeze it!
            for (let i = lineBufferQueue.length - 1; i >= 0; i--) {
                let item = lineBufferQueue[i];
                if (item.isJustNewline && !item.isProtectedNewline) {
                    lineBufferQueue.splice(i, 1);
                    
                    // Recalculate to see if we saved the pagination event
                    vLines = linesPrinted;
                    vAllow = allowPagination;
                    triggersPagination = false;
                    for (let testItem of lineBufferQueue) {
                        if (testItem.unlocksPagination) {
                            vAllow = true;
                            vLines = 0;
                        }
                        if (testItem.isClearScreen) vLines = 0;
                        if (!testItem.isPrompt && testItem.hasNewline) {
                            vLines++;
                            if (vAllow && vLines >= 25) triggersPagination = true;
                        }
                    }
                    if (!triggersPagination) break; // Saved!
                }
            }
        }

        // 3. Final Emit
        while (lineBufferQueue.length > 0) {
            if (isPaused) break; // Retain remaining queue until unpaused
            
            let item = lineBufferQueue.shift();
            lastWasEmptyLine = item.isJustNewline;

            if (item.unlocksPagination) {
                allowPagination = true;
                linesPrinted = 0; // Fresh page reset since the MUD just issued its own prompt
            }

            if (item.isClearScreen) {
                linesPrinted = 0;
                cursorAtStartOfLine = true;
            }

            this.terminal.writeRaw(item.line);

            if (item.hasNewline) {
                cursorAtStartOfLine = true;
                // The cursor moved to a fresh line; any prior in-progress
                // prompt-fragment can no longer be the parent of a future
                // continuation, so drop the alignment-merge state.
                pendingPromptFragment = null;
            } else {
                cursorAtStartOfLine = false;
                // We just wrote bytes that left the cursor mid-row. If this
                // was a prompt-style emit (no trailing newline), remember
                // its ANSI-stripped text so a later chunk can complete the
                // visible row and merge into `prevPlainText` correctly. If
                // the same prompt-fragment is later confirmed to be a real
                // prompt by the user typing into it, the keypress handler
                // will clear this state.
                if (item.isPrompt) {
                    pendingPromptFragment = item.plainText;
                } else {
                    pendingPromptFragment = null;
                }
            }

            if (!item.isPrompt && item.hasNewline) {
                linesPrinted++;
                
                clearTimeout(burstTimer);
                // 500ms inactivity safely indicates the burst of remote text is finished
                burstTimer = setTimeout(() => { 
                    linesPrinted = 0; 
                }, 500);
                
                if (allowPagination && linesPrinted >= 25) {
                    isPaused = true;
                    socket.pause();
                    this.terminal.setColor(Color.BRIGHT_WHITE, Color.BLUE);
                    this.terminal.writeRaw('\r\x1b[K ... hit any key for more ... ');
                    this.terminal.resetAttrs();
                }
            }
        }
      };

      // Detect a horizontal box-drawing border row and record its left/right
      // edge columns. Border rows consist of dash glyphs between corner or
      // junction glyphs, optionally with leading/trailing whitespace (e.g.
      // an indented inner box).
      const recordIfBorderRow = (plain) => {
        const trimmedStart = plain.search(/\S/);
        if (trimmedStart < 0) return;
        const trimmed = plain.replace(/\s+$/, '');
        const leftIdx = trimmedStart;
        const rightIdx = trimmed.length - 1;
        if (rightIdx <= leftIdx) return;
        if (BOX_LEFT_CHARS.indexOf(plain[leftIdx]) < 0) return;
        if (BOX_RIGHT_CHARS.indexOf(plain[rightIdx]) < 0) return;
        // The interior between the two corners should be predominantly the
        // horizontal dash glyph.
        let dashCount = 0;
        const interiorLen = rightIdx - leftIdx - 1;
        for (let i = leftIdx + 1; i < rightIdx; i++) {
          if (plain[i] === BOX_DASH) dashCount++;
        }
        if (dashCount < interiorLen * 0.8) return;
        boxRightEdges.set(leftIdx, rightIdx);
      };

      // Pad a content row whose left ║ matches a tracked box so its closing
      // ║ sits at the recorded right-edge column. Returns the padded line
      // and plainText, or null if no repair was needed/possible. ║ is a
      // non-ANSI byte so locating it via lastIndexOf is safe with respect
      // to embedded escape sequences.
      const repairBoxRow = (line, plain) => {
        if (boxRightEdges.size === 0) return null;
        const firstNonWs = plain.search(/\S/);
        if (firstNonWs < 0 || plain[firstNonWs] !== BOX_BAR) return null;
        const trimmed = plain.replace(/\s+$/, '');
        const lastIdx = trimmed.length - 1;
        if (lastIdx <= firstNonWs || plain[lastIdx] !== BOX_BAR) return null;
        const expectedRight = boxRightEdges.get(firstNonWs);
        if (expectedRight === undefined) return null;
        const deficit = expectedRight - lastIdx;
        if (deficit <= 0) return null;
        const lastBarInLine = line.lastIndexOf(BOX_BAR);
        if (lastBarInLine < 0) return null;
        const pad = ' '.repeat(deficit);
        const newLine = line.substring(0, lastBarInLine) + pad + line.substring(lastBarInLine);
        const newPlain = plain.substring(0, lastIdx) + pad + plain.substring(lastIdx);
        return { line: newLine, plainText: newPlain };
      };

      const queueLine = (line, isPrompt) => {
        const ansiRegex = /\x1b\[[0-9;]*[a-zA-Z]/g;
        let plainText = line.replace(ansiRegex, '').replace(/[\r\n]/g, '');

        // Detect the first instance of a prompt so we can unlock pagination later in the stream loop
        let unlocksPagination = false;
        if (!seenPaginationUnlock && plainText.toLowerCase().includes('press any key')) {
            seenPaginationUnlock = true;
            unlocksPagination = true;
        }

        // Resolve clear-screen state up front. The reset must precede box
        // and squash logic so a clear-screen escape that arrives in the
        // SAME line as a fresh box border (a common case — a redraw burst
        // begins with `\x1b[2J\x1b[H` immediately followed by the top
        // ╔═══╗) doesn't wipe the box width we are about to record from
        // that very same line.
        const isClearScreen = /\x1b\[(2J|H|1;1H)/.test(line);
        if (isClearScreen) {
            prevPlainText = '';
            pendingPromptFragment = null;
            boxRightEdges.clear();
        }

        // Box-drawing alignment repair: pad short ║...║ content rows out to
        // the most-recently-seen border row's width, then update tracked
        // widths from any border row we see. Must run BEFORE squashing so
        // any padding is correctly width-checked against the 80-col cap.
        if (plainText.indexOf(BOX_BAR) >= 0 || plainText.indexOf(BOX_DASH) >= 0) {
          const repaired = repairBoxRow(line, plainText);
          if (repaired) {
            line = repaired.line;
            plainText = repaired.plainText;
          }
          recordIfBorderRow(plainText);
        }

        if (plainText.length > 80) {
          const squashed = applySquashing(line, plainText, prevPlainText);
          if (squashed) {
            line = squashed.line;
            plainText = squashed.plainText;
          }
        }
        
        const isBlankText = plainText.trim().length === 0;

        // Update the alignment anchor used by the next squashable line.
        // Normally this is just the current line's plain text, but when an
        // earlier prompt-style emit left the cursor mid-row (the previous
        // server send was a TCP-fragmented partial line, or a real prompt
        // about to be answered), the visually-prior row is the merge of
        // that fragment plus this completion. Anchoring on just `plainText`
        // (e.g. just "4  " when a row got split) would falsely place a
        // "word at column 0" above the next row and trick the squasher's
        // leading-whitespace bonus into firing — visibly de-indenting that
        // next row. Merging keeps the anchor faithful to what the user
        // actually sees on screen.
        if (!isClearScreen && !isBlankText) {
            if (pendingPromptFragment !== null) {
                prevPlainText = pendingPromptFragment + plainText;
                pendingPromptFragment = null;
            } else {
                prevPlainText = plainText;
            }
        }

        const isJustNewline = isBlankText && line.includes('\n');
        const hasNewline = line.includes('\n');

        lineBufferQueue.push({
            line,
            plainText,
            isPrompt,
            isJustNewline,
            isClearScreen,
            hasNewline,
            unlocksPagination
        });

        // Prompts and clears skip the buffer to preserve instant responsiveness
        if (isPrompt || isClearScreen) {
            if (queueTimer) clearTimeout(queueTimer);
            flushQueue();
        } else if (!queueTimer) {
            queueTimer = setTimeout(flushQueue, SMART_PAGINATION_BUFFER_MS);
        }
      };

      const processBuffer = () => {
        if (isPaused) return;

        // Process full lines
        while (lineBuffer.includes('\n')) {
          const idx = lineBuffer.indexOf('\n');
          const line = lineBuffer.substring(0, idx + 1);
          lineBuffer = lineBuffer.substring(idx + 1);

          queueLine(line, false);
          
          // Bail out of processing loop immediately if pagination triggered
          if (isPaused) return; 
        }

        // Handle prompts (text that doesn't end in a newline, waiting for user input)
        clearTimeout(promptTimeout);
        if (lineBuffer.length > 0) {
          promptTimeout = setTimeout(() => {
            if (isPaused) return;
            queueLine(lineBuffer, true);
            lineBuffer = '';
          }, 50); // Flush buffer to screen if 50ms pass without a newline
        }
      };

      // --- INCOMING DATA HANDLER ---
      socket.on('data', (chunk) => {
        const textBytes = [];

        // 1. Strip Telnet IAC (0xFF) protocol bytes
        for (let i = 0; i < chunk.length; i++) {
          const b = chunk[i];
          if (iacState === 0) {
            if (b === 255) { iacState = 1; } 
            else { textBytes.push(b); }      
          } else if (iacState === 1) {
            if (b === 250) { iacState = 3; } 
            else if (b >= 251 && b <= 254) { iacState = 2; } 
            else if (b === 255) { textBytes.push(255); iacState = 0; }
            else { iacState = 0; }
          } else if (iacState === 2) {
            iacState = 0; 
          } else if (iacState === 3) {
            if (b === 255) { iacState = 4; } 
          } else if (iacState === 4) {
            if (b === 240) { iacState = 0; } 
            else if (b === 255) { iacState = 3; } 
            else { iacState = 3; } 
          }
        }

        // 2. Decode UTF-8
        const decodedStr = utf8Decoder.write(Buffer.from(textBytes));
        
        // Disable local echo if we see a standard prompt
        if (echoLocally) {
          recentTextBuffer += decodedStr;
          if (recentTextBuffer.length > 512) recentTextBuffer = recentTextBuffer.slice(-512);
          const plainTextCheck = recentTextBuffer.replace(/\x1b\[[0-9;]*[a-zA-Z]/g, '');
          if (plainTextCheck.toLowerCase().includes('press any key')) {
            echoLocally = false; 
          }
        }

        // 3. Map to CP437 with advanced Unicode Fallback
        let cp437Out = '';
        for (let i = 0; i < decodedStr.length; i++) {
          const char = decodedStr[i];
          const charCode = char.charCodeAt(0);

          if (charCode < 128) {
            cp437Out += char;
          } else if (UNICODE_TO_CP437[char]) {
            cp437Out += UNICODE_TO_CP437[char];
          } else {
            // Dynamic Fallback: Strip diacritics (e.g. 'é' -> 'e')
            const normalized = char.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            if (normalized.length > 0 && normalized.charCodeAt(0) < 128) {
              cp437Out += normalized.charAt(0);
            } else {
              cp437Out += '?';
            }
          }
        }

        // 4. Feed stream processor
        lineBuffer += cp437Out;
        processBuffer();
      });

      socket.on('close', () => {
        this.terminal.setColor(Color.BRIGHT_RED, Color.BLACK);
        this.terminal.println('\n\n[Connection closed by remote host]');
        this.terminal.resetAttrs();
        setTimeout(cleanup, 1500);
      });

      socket.on('error', (err) => {
        this.terminal.setColor(Color.BRIGHT_RED, Color.BLACK);
        this.terminal.println(`\n\n[Connection error: ${err.message}]`);
        this.terminal.resetAttrs();
        setTimeout(cleanup, 2000);
      });

      const sendToSocket = (str) => {
        if (connected && !socket.destroyed) {
          socket.write(str, 'binary');
        }
      };

      // --- LOCAL KEY HANDLER ---
      const keyHandler = (key) => {
        // Handle forced disconnect
        if (key === '\x1d') {
          this.terminal.setColor(Color.BRIGHT_YELLOW, Color.BLACK);
          this.terminal.println('\n\n[Disconnecting...]');
          this.terminal.resetAttrs();
          cleanup();
          return;
        }

        // Handle Pagination Resume Event
        if (isPaused) {
          isPaused = false;
          linesPrinted = 0;
          clearTimeout(burstTimer);
          this.terminal.writeRaw('\r\x1b[K'); // Erase the pagination prompt completely
          socket.resume(); // Resume ingesting remote TCP data
          flushQueue(); // Prioritize any lines held in the spool before the pause
          processBuffer(); // Process any data that was stranded in the TCP line buffer
          return; // Consume the keypress so it doesn't go to the remote server
        }

        const KEY_MAP = {
          'UP': '\x1b[A', 'ArrowUp': '\x1b[A',
          'DOWN': '\x1b[B', 'ArrowDown': '\x1b[B',
          'RIGHT': '\x1b[C', 'ArrowRight': '\x1b[C',
          'LEFT': '\x1b[D', 'ArrowLeft': '\x1b[D',
          'PAGEUP': '\x1b[5~', 'PageUp': '\x1b[5~',
          'PAGEDOWN': '\x1b[6~', 'PageDown': '\x1b[6~',
          'HOME': '\x1b[1~', 'Home': '\x1b[1~',
          'END': '\x1b[4~', 'End': '\x1b[4~',
          'INSERT': '\x1b[2~', 'Insert': '\x1b[2~',
          'DELETE': '\x1b[3~', 'Delete': '\x1b[3~',
          'BACKSPACE': '\x08', 'Backspace': '\x08',
          'ENTER': '\r', 'Enter': '\r', 'RETURN': '\r', 'Return': '\r',
          'TAB': '\t', 'Tab': '\t',
          'ESCAPE': '\x1b', 'Escape': '\x1b',
        };

        const out = KEY_MAP[key] !== undefined ? KEY_MAP[key] : key;
        
        sendToSocket(out);

        // Always break continuous output formatting loops if the user sends an execution command
        if (out === '\r') {
          lastWasEmptyLine = false; 
        }

        if (echoLocally) {
          if (out === '\x08') {
            this.terminal.writeRaw('\b \b'); 
          } else if (out === '\r') {
            this.terminal.writeRaw('\r\n');
          } else if (out.length === 1 && out.charCodeAt(0) >= 32 && out.charCodeAt(0) <= 126) {
            this.terminal.writeRaw(out); 
          }
        }
      };

      this.terminal.on('key', keyHandler);
    });
  }
}

module.exports = UsurperReborn;