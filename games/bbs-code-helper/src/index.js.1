/**
 * Macro substitution map. Each key is a literal token that appears in
 * INTRO_LINES, RECIPES, or FOOTER_LINES; each value is a function that
 * receives the runtime context and returns the replacement string.
 *
 * Add your own macros here if you template additional values into the
 * prose — they'll be substituted in every editable string before render.
 */
const MACROS = {
  '@HOST@':     (ctx) => ctx.host,
  '@PORT@':     (ctx) => String(ctx.port),
  '@BBSCODE@':  (ctx) => ctx.bbsCode,
  '@USERNAME@': (ctx) => ctx.username,
};

// ═══════════════════════════════════════════════════════════════════════════
//                          END EDITABLE CONFIG
// ═══════════════════════════════════════════════════════════════════════════
//
// Below: rendering and flow control. You generally won't need to edit
// anything past this point.
//

/** Replace every macro token in `s` with its expanded value. */
function expand(s, ctx) {
  let out = String(s);
  for (const [token, fn] of Object.entries(MACROS)) {
    if (out.includes(token)) {
      out = out.split(token).join(fn(ctx));
    }
  }
  return out;
}

/** Apply expansion to every line of an array. */
function expandLines(lines, ctx) {
  return lines.map(line => expand(line, ctx));
}

class BBSCodeHelper extends GameBase {
  static get GAME_NAME()  { return 'bbs-code-helper'; }
  static get GAME_TITLE() { return 'BBS Code Helper'; }

  async run() {
    this.screen.setMode(Screen.SCROLL);
    this.terminal.clearScreen();

    // Determine auth mode (so we can show the naive-mode notice when relevant).
    const authMode = (this.config.authMode || 'naive').toLowerCase();
    const isAuthenticated = authMode === 'authenticated';

    // Mint a fresh BBS code via the shared SynthAuth instance.
    let bbsCode;
    try {
      bbsCode = getAuth().generateBBSCode();
    } catch (err) {
      // SynthAuth not initialised — server probably can't issue codes at all.
      this.terminal.setColor(Color.BRIGHT_RED, Color.BLACK);
      this.terminal.println('');
      this.terminal.println('  This SynthDoor server does not have SynthAuth initialised.');
      this.terminal.println('  BBS Codes cannot be generated. Please contact the operator.');
      this.terminal.println('');
      this.terminal.resetAttrs();
      await this._pressAnyKey('Press any key to exit...');
      return;
    }

    getLogger().info(`[BBSCodeHelper] code issued to user=${this.username} authMode=${authMode}`);

    const server = SERVER_INFO(this.config);
    const ctx = {
      host:     server.host,
      port:     server.port,
      bbsCode:  bbsCode,
      username: this.username || 'YOUR_USER',
    };

    // ── Screen 1: intro + the freshly-minted code ────────────────────────
    await this._showIntro(ctx, isAuthenticated);
    if (!this._running) return;

    // ── Screen 2..N: one screen per recipe ───────────────────────────────
    for (let i = 0; i < RECIPES.length; i++) {
      await this._showRecipe(RECIPES[i], ctx, i + 1, RECIPES.length);
      if (!this._running) return;
    }

    // ── Final screen: footer ─────────────────────────────────────────────
    await this._showFooter(ctx);
  }

  // ─── Screen renderers ────────────────────────────────────────────────────

  async _showIntro(ctx, isAuthenticated) {
    this._running = true;
    this.terminal.clearScreen();
    this._header('BBS Code Helper', 'Step 1 of ' + (RECIPES.length + 2));

    this.terminal.setColor(Color.WHITE, Color.BLACK);
    for (const line of expandLines(INTRO_LINES, ctx)) {
      this.terminal.println(line);
    }

    // Display the code in a prominent box
    this.terminal.setColor(Color.BRIGHT_GREEN, Color.BLACK);
    this.terminal.println('  ┌────────────────────────────────────────────────────────────┐');
    this.terminal.println('  │                                                            │');
    this.terminal.println('  │   Your BBS Code:   ' + this._padCentred(ctx.bbsCode, 39)  + '│');
    this.terminal.println('  │                                                            │');
    this.terminal.println('  │   Reachable at:    ' + this._padCentred(`${ctx.host}:${ctx.port}`, 39) + '│');
    this.terminal.println('  │                                                            │');
    this.terminal.println('  └────────────────────────────────────────────────────────────┘');
    this.terminal.resetAttrs();

    if (!isAuthenticated) {
      this.terminal.setColor(Color.BRIGHT_YELLOW, Color.BLACK);
      for (const line of expandLines(NAIVE_MODE_NOTICE, ctx)) {
        this.terminal.println(line);
      }
      this.terminal.resetAttrs();
    }

    await this._pressAnyKey('Press any key to see the per-BBS connection recipes...');
  }

  async _showRecipe(recipe, ctx, stepNum, totalRecipes) {
    if (!this._running) return;
    this.terminal.clearScreen();
    this._header(recipe.name, `Step ${stepNum + 1} of ${totalRecipes + 2}`);

    this.terminal.setColor(Color.WHITE, Color.BLACK);
    this.terminal.println('');
    for (const line of expandLines(recipe.notes, ctx)) {
      this.terminal.println('  ' + line);
    }
    this.terminal.resetAttrs();

    // Each example: a label in cyan, then the command in bright white,
    // boxed so it's visually scannable.
    for (const ex of recipe.examples) {
      this.terminal.println('');
      this.terminal.setColor(Color.BRIGHT_CYAN, Color.BLACK);
      this.terminal.println('  ' + ex.label + ':');
      this.terminal.resetAttrs();

      this.terminal.setColor(Color.BRIGHT_WHITE, Color.BLACK);
      const expanded = expand(ex.command, ctx);
      for (const cmdLine of expanded.split('\n')) {
        this.terminal.println('    ' + cmdLine);
      }
      this.terminal.resetAttrs();
    }

    this.terminal.println('');
    await this._pressAnyKey('Press any key for the next recipe...');
  }

  async _showFooter(ctx) {
    if (!this._running) return;
    this.terminal.clearScreen();
    this._header('All done', `Step ${RECIPES.length + 2} of ${RECIPES.length + 2}`);

    this.terminal.setColor(Color.WHITE, Color.BLACK);
    for (const line of expandLines(FOOTER_LINES, ctx)) {
      this.terminal.println(line);
    }
    this.terminal.resetAttrs();

    // Re-show the code one more time so they don't have to scroll back
    this.terminal.setColor(Color.BRIGHT_GREEN, Color.BLACK);
    this.terminal.println('  Your BBS Code (note this down):  ' + ctx.bbsCode);
    this.terminal.resetAttrs();
    this.terminal.println('');

    await this._pressAnyKey('Press any key to exit...');
  }

  // ─── Small helpers ───────────────────────────────────────────────────────

  _header(title, subtitle) {
    this.terminal.setColor(Color.BRIGHT_WHITE, Color.BLUE);
    // Top bar — 79 chars wide, leaving column 80 blank to avoid the
    // eager-wrap-with-CRLF double-row trap (see CLAUDE.md Rule 6).
    const bar = ' ' + title + this._spaces(79 - 1 - title.length - subtitle.length - 1) + subtitle + ' ';
    this.terminal.println(bar.length > 79 ? bar.slice(0, 79) : bar);
    this.terminal.resetAttrs();
  }

  _spaces(n) { return n > 0 ? ' '.repeat(n) : ''; }

  _padCentred(s, width) {
    s = String(s);
    if (s.length >= width) return s.slice(0, width);
    const left  = Math.floor((width - s.length) / 2);
    const right = width - s.length - left;
    return this._spaces(left) + s + this._spaces(right);
  }

  async _pressAnyKey(prompt) {
    this.terminal.println('');
    this.terminal.setColor(Color.BRIGHT_YELLOW, Color.BLACK);
    this.terminal.print('  ' + prompt + ' ');
    this.terminal.resetAttrs();
    const key = await this.terminal.waitKey();
    this.terminal.println('');
    // Allow Q or ESC to bail early
    if (key === 'q' || key === 'Q' || key === '\x1b' || key === 'ESCAPE' || key === 'Escape') {
      this._running = false;
    }
  }
}

module.exports = BBSCodeHelper;
