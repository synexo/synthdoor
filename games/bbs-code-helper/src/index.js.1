'use strict';

/**
 * games/bbs-code-helper/src/index.js
 *
 * Helper for visiting BBS operators who want to wire their BBS into
 * SynthDoor via rlogin so that their users can connect.
 *
 * What it does:
 *   1) Generates a fresh BBS Code (the XXXX-XXXX value the partner BBS
 *      will place in the rlogin ServerUser field for silent auto-login).
 *   2) Walks the operator through a per-BBS-software cheat-sheet showing
 *      the exact connection strings for Synchronet, Mystic, WWIV,
 *      telnetdoor.exe, and a generic rlogin form.
 *
 * Open to all users — anyone (sysop or otherwise) can mint a code for
 * their own BBS. The codes generated here are interchangeable with any
 * other SynthDoor recovery code, so the helper simply hands one over and
 * trusts the operator to install it on their own BBS.
 *
 * ┌──────────────────────────────────────────────────────────────────────┐
 * │  All operator-facing text and example connection strings live in     │
 * │  the EDITABLE CONFIG block below. Edit those constants freely — the  │
 * │  rest of the file is just plumbing that displays them.               │
 * └──────────────────────────────────────────────────────────────────────┘
 */

const path = require('path');

const { GameBase, Screen, Color } = require(
  path.join(__dirname, '..', '..', '..', 'packages', 'engine', 'src', 'index.js')
);
const { getAuth } = require(
  path.join(__dirname, '..', '..', '..', 'packages', 'server', 'src', 'auth-flow.js')
);
const { getLogger } = require(
  path.join(__dirname, '..', '..', '..', 'packages', 'server', 'src', 'logger.js')
);

// ═══════════════════════════════════════════════════════════════════════════
//                         BEGIN EDITABLE CONFIG
// ═══════════════════════════════════════════════════════════════════════════
//
// Everything between BEGIN and END EDITABLE CONFIG is meant for the
// SynthDoor operator to edit. The rest of the file just renders what's
// defined here.
//
// Four things you may want to change:
//
//   1) SERVER_INFO — the host/port at which your SynthDoor is reachable
//      from a remote BBS. Defaults try to read from the engine config;
//      override host if your public DNS name differs from your bind
//      address (typical behind NAT).
//
//   2) INTRO_LINES, NAIVE_MODE_NOTICE, FOOTER_LINES — the prose shown
//      around the code and the recipes. Each is an array of strings,
//      one per line. Empty strings render as blank lines.
//
//   3) RECIPES — the per-BBS-software cheat-sheets. Each recipe has a
//      `name`, a `notes` array, and one or more `examples` (a label
//      plus a connection-string template). The order here is the order
//      shown to operators.
//
//   4) MACROS — the placeholder substitutions applied to the strings in
//      INTRO_LINES, recipes, and FOOTER_LINES. By default they expand
//      the host, port, BBS code, and username. Add your own if you
//      want to template additional values.
//
// ───────────────────────────────────────────────────────────────────────────

/**
 * Public-facing connection details for *your* SynthDoor instance.
 * Used to expand @HOST@ and @PORT@ in the example connection strings.
 *
 * `config` here is the engine-supplied per-game config dict, which
 * exposes top-level keys from synthdoor.conf.
 */
const SERVER_INFO = (config) => ({
  // The hostname or IP that partner BBSes should rlogin to.
  // Defaults to a placeholder — set `public_hostname` in synthdoor.conf
  // under [game:bbs-code-helper] to override per-instance.
  host: config.public_hostname || 'your-synthdoor-host.example.com',

  // The rlogin port. Defaults to the server-wide rlogin_port (usually
  // 1513). If you've forwarded it to the standard 513, change this.
  port: config.public_rlogin_port || config.rlogin_port || 1513,
});

/**
 * Lines shown on the first screen, above the freshly-generated BBS Code.
 */
const INTRO_LINES = [
  '',
  '  Welcome to the BBS Code Helper.',
  '',
  '  This tool generates a "BBS Code" for partner BBSes to use when',
  '  connecting their users to this SynthDoor server via rlogin.',
  '',
  '  How it works:',
  '',
  '    A BBS Code is a one-time key (formatted XXXX-XXXX) that an',
  '    operator installs on their BBS. When one of their users launches',
  '    a SynthDoor game, the BBS opens an rlogin connection to us with',
  '    the user\'s name in ClientUser, the code in ServerUser, and an',
  '    optional game name in TermType. SynthDoor recognises the code,',
  '    silently logs the user in, and drops them into the game (or the',
  '    main menu, if no game was specified).',
  '',
  '  When you press a key, a fresh code will be minted. Note it down',
  '  somewhere safe — you\'ll paste it into your BBS configuration.',
  '',
];

/**
 * Shown only if the server is currently running in `naive` auth mode.
 * Recovery codes only have effect in `authenticated` mode, so warn the
 * operator that the code will not silently log anyone in until the
 * SynthDoor sysop flips auth_mode = authenticated in synthdoor.conf.
 */
const NAIVE_MODE_NOTICE = [
  '',
  '  ┌─ NOTICE ──────────────────────────────────────────────────────┐',
  '  │                                                               │',
  '  │  This SynthDoor server is currently running in NAIVE auth     │',
  '  │  mode. BBS Codes only function in AUTHENTICATED mode.         │',
  '  │                                                               │',
  '  │  The code below is still valid; it will start working as soon │',
  '  │  as the SynthDoor operator switches modes in synthdoor.conf.  │',
  '  │                                                               │',
  '  └───────────────────────────────────────────────────────────────┘',
  '',
];

/**
 * Lines shown after the last recipe, before the exit prompt.
 */
const FOOTER_LINES = [
  '',
  '  Need to mint another code? Just relaunch this game. Each code is',
  '  independent — you can hand a different one to each partner BBS, or',
  '  rotate codes whenever you like.',
  '',
  '  If you run into trouble wiring this up, the SynthDoor source has',
  '  the full rlogin handshake documented in:',
  '',
  '    packages/server/src/transports/rlogin.js',
  '',
  '  Thanks for federating with us!',
  '',
];

/**
 * Per-BBS-software connection recipes. Each entry produces one screen.
 *
 * Each recipe has:
 *   - `name`     : Header shown at the top of the screen.
 *   - `notes`    : An array of strings shown above the examples. Wrap
 *                  your own paragraphs by ending lines at column ~75.
 *   - `examples` : An array of { label, command } pairs. The command
 *                  string can be multi-line (use \n) and may use the
 *                  macros listed in MACROS below.
 *
 * The order here is the order operators see them. Trim or extend at will.
 */
const RECIPES = [
  // ─── Synchronet ────────────────────────────────────────────────────────
  {
    name: 'Synchronet',
    notes: [
      'Add a new external program entry (xtrn.cnf) or door menu item',
      'that uses the SyncTERM rlogin client to connect out. The trick is',
      'getting the rlogin handshake right:',
      '',
      '  ClientUser  →  the user\'s alias on YOUR BBS',
      '  ServerUser  →  your BBS Code (the XXXX-XXXX value below)',
      '  TermType    →  blank for menu, or a SynthDoor game name to',
      '                 launch directly into that game (e.g. meteoroid)',
    ],
    examples: [
      {
        label: 'Launch SynthDoor main menu',
        command:
          '?rlogin @HOST@:@PORT@ -h -s@BBSCODE@ -q -tANSI',
      },
      {
        label: 'Launch directly into a specific game (Meteoroid)',
        command:
          '?rlogin @HOST@:@PORT@ -h -s@BBSCODE@ -q -tmeteoroid',
      },
      {
        label: 'Inside an external_command.ini door definition',
        command:
          '[Door]\n' +
          'name        = SynthDoor\n' +
          'cmd         = ?rlogin @HOST@:@PORT@ -h -s@BBSCODE@ -q -tANSI\n' +
          'stdio       = -\n' +
          'native      = true\n' +
          'multinode   = true',
      },
    ],
  },

  // ─── Mystic ────────────────────────────────────────────────────────────
  {
    name: 'Mystic BBS',
    notes: [
      'Mystic ships with the rlogin.exe / rlogin client. Add a menu',
      'command of type GE (Gosub External) or use a doors.dat entry,',
      'pointing at the client with the parameters below.',
      '',
      'The /PROMPT flag in the rlogin client hides the connection details',
      'from your callers — recommended for production use.',
    ],
    examples: [
      {
        label: 'Launch SynthDoor main menu',
        command:
          '/addr=@HOST@ /port=@PORT@ /user=@USERNAME@ /pass=@BBSCODE@ /term=ANSI /PROMPT',
      },
      {
        label: 'Launch directly into a specific game (Meteoroid)',
        command:
          '/addr=@HOST@ /port=@PORT@ /user=@USERNAME@ /pass=@BBSCODE@ /term=meteoroid /PROMPT',
      },
    ],
  },

  // ─── WWIV ──────────────────────────────────────────────────────────────
  {
    name: 'WWIV',
    notes: [
      'WWIV supports rlogin via the //net rlogin or built-in chain',
      'configuration. Add a new chain entry whose command line invokes',
      'an rlogin client with the parameters below. Many sysops use',
      'telnetdoor.exe or a similar Windows rlogin shim.',
    ],
    examples: [
      {
        label: 'Generic WWIV chain command line',
        command:
          'rlogin @HOST@ @PORT@ -l @USERNAME@ -s @BBSCODE@ -t ANSI',
      },
    ],
  },

  // ─── telnetdoor.exe (DOS / Windows door shim) ──────────────────────────
  {
    name: 'telnetdoor.exe (DOS / Windows door shim)',
    notes: [
      'Widely used to bridge legacy DOS doors to rlogin servers. The',
      'magic flags are:',
      '',
      '  -R               use rlogin instead of telnet',
      '  -S<host>:<port>  remote server',
      '  -Y"<user>"       ClientUser (your BBS user)',
      '  -X"<password>"   ServerUser (the BBS Code)',
      '  -Z<term>         TermType (game name or "ANSI")',
      '  -D<dropfile>     path to door32.sys / dorinfo1.def from the BBS',
      '',
      'A typical menu invocation looks like:',
    ],
    examples: [
      {
        label: 'Launch SynthDoor main menu',
        command:
          'telnetdoor.exe -R -S@HOST@:@PORT@ -Y"@USERNAME@" -X"@BBSCODE@" -ZANSI -D%1 -W0',
      },
      {
        label: 'Launch directly into a specific game (Meteoroid)',
        command:
          'telnetdoor.exe -R -S@HOST@:@PORT@ -Y"@USERNAME@" -X"@BBSCODE@" -Zmeteoroid -D%1 -W0',
      },
    ],
  },

  // ─── Generic rlogin reference ──────────────────────────────────────────
  {
    name: 'Generic rlogin (anything else)',
    notes: [
      'For BBS software not listed above, the underlying rlogin wire',
      'format is just three null-terminated strings on top of a TCP',
      'connection to port @PORT@:',
      '',
      '  \\0 <ClientUser> \\0 <ServerUser> \\0 <TermType> \\0',
