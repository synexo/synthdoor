'use strict';
const path = require('path');
const tls = require('tls');
const { URL } = require('url');

// CRITICAL: Always use path.join for engine imports
const { GameBase, Screen, Color } = require(
  path.join(__dirname, '..', '..', '..', 'packages', 'engine', 'src', 'index.js')
);

// CRITICAL: Import Utils DIRECTLY from utils.js
const Utils = require(
  path.join(__dirname, '..', '..', '..', 'packages', 'engine', 'src', 'utils.js')
);

const SYNTHDOOR_HOME_URL = 'synthdoor://home';
const HOME_GEMTEXT = `# SynthDoor Geminispace
Welcome to the Gemini protocol. This browser traverses the modern, lightweight web over TLS.

## Getting Started
=> gemini://geminispace.info/ Geminispace Directory & Search Engine
=> gemini://medusae.space/ Medusae.space Directory
=> gemini://geminiquickst.art/ Gemini Quickstart Guide

## Communities & Capsules
=> gemini://station.martin-brennan.com/ Station (Geminispace Aggregator)
=> gemini://flounder.online/ Flounder (Gemini Hosting)
=> gemini://gemi.dev/ Gemi.dev

## Navigation Tips
* Press [Enter] to scroll through documents.
* Enter a link number at the prompt to follow it.
* Type [u] to manually enter a new gemini:// URL.
* Type [b] to go back or [q] to quit.
`;

class GeminiBrowser extends GameBase {
  static get GAME_NAME() { return 'gemini-browser'; }
  static get GAME_TITLE() { return 'Gemini Browser'; }

  async run() {
    this.screen.setMode(Screen.SCROLL);
    this.terminal.clearScreen();
    
    this.terminal.setColor(Color.BRIGHT_WHITE, Color.MAGENTA);
    this.terminal.println(Utils.center(' G E M I N I   B R O W S E R ', 80));
    this.terminal.resetAttrs();

    // Stack to manage navigation history
    let history = [SYNTHDOOR_HOME_URL];

    while (history.length > 0) {
      let currentUrl = history[history.length - 1];
      
      const action = await this._navigate(currentUrl);
      
      if (action === 'quit') {
        break;
      } else if (action === 'back') {
        history.pop();
      } else if (action && action.type === 'nav') {
        history.push(action.url);
      } else {
        // Fallback for unexpected returns or stays
        history.pop();
      }
    }
    
    this._exitApp();
  }

  // --- Network Layer ---

  async _fetchGemini(urlStr, redirectCount = 0) {
    // Set to false to silence server console logs once working
    const DEBUG = true;

    if (redirectCount > 5) {
      if (DEBUG) this.log(`[GEMINI DEBUG] Too many redirects.`);
      return { error: 'Too many redirects.' };
    }

    if (urlStr === SYNTHDOOR_HOME_URL) {
      return { status: '20', meta: 'text/gemini', body: Buffer.from(HOME_GEMTEXT, 'utf8') };
    }

    this.terminal.setColor(Color.DARK_GRAY, Color.BLACK);
    this.terminal.println(`\nFetching ${urlStr}...`);
    this.terminal.resetAttrs();

    let url;
    try {
      url = new URL(urlStr);
    } catch (e) {
      if (DEBUG) this.log(`[GEMINI DEBUG] URL Parse Error: ${e.message} for ${urlStr}`);
      return { error: 'Invalid URL format.' };
    }

    if (url.protocol !== 'gemini:') {
      return { error: `Unsupported protocol: ${url.protocol}` };
    }

    // Always use url.href as the request string to ensure trailing slashes 
    // are properly applied (e.g. "gemini://host" becomes "gemini://host/")
    const requestUrl = url.href;

    return new Promise((resolve) => {
      let resolved = false;
      const done = (result) => {
        if (!resolved) {
          resolved = true;
          resolve(result);
        }
      };

      // Gemini requires TLS, SNI (servername), and TOFU (self-signed certs)
      const options = {
        host: url.hostname,
        port: parseInt(url.port || '1965', 10),
        rejectUnauthorized: false, 
        servername: url.hostname,
        minVersion: 'TLSv1.2',
        ALPNProtocols: ['gemini']
      };

      if (DEBUG) this.log(`[GEMINI DEBUG] Connecting to ${options.host}:${options.port}`);

      let client;
      try {
        client = tls.connect(options);
      } catch (err) {
        if (DEBUG) this.log(`[GEMINI DEBUG] tls.connect sync throw: ${err.message}`);
        return done({ error: `Connection setup error: ${err.message}` });
      }

      let data = Buffer.alloc(0);
      client.setTimeout(10000);

      client.on('secureConnect', () => {
        if (DEBUG) {
          const cipher = client.getCipher();
          this.log(`[GEMINI DEBUG] Secure connection established: ${cipher.name} (${client.getProtocol()})`);
          this.log(`[GEMINI DEBUG] Sending request: ${requestUrl}`);
        }
        client.write(requestUrl + '\r\n');
      });

      client.on('data', (chunk) => {
        if (DEBUG && data.length === 0) this.log(`[GEMINI DEBUG] Receiving first data chunk (${chunk.length} bytes)...`);
        data = Buffer.concat([data, chunk]);
      });

      client.on('end', async () => {
        if (DEBUG) this.log(`[GEMINI DEBUG] Connection ended. Total payload: ${data.length} bytes.`);
        
        const headerEnd = data.indexOf('\r\n');
        if (headerEnd === -1) {
          if (DEBUG) this.log(`[GEMINI DEBUG] Malformed response, no CRLF terminator.`);
          return done({ error: 'Malformed response.' });
        }
        
        const header = data.subarray(0, headerEnd).toString('utf8');
        if (DEBUG) this.log(`[GEMINI DEBUG] Header parsed: ${header}`);
        
        const body = data.subarray(headerEnd + 2);
        
        const spaceIdx = header.indexOf(' ');
        if (spaceIdx === -1) {
          return done({ error: 'Malformed header.' });
        }

        const status = header.substring(0, spaceIdx);
        const meta = header.substring(spaceIdx + 1);

        if (status.startsWith('1')) {
          // 1x: Input Required
          this.terminal.setColor(Color.BRIGHT_CYAN, Color.BLACK);
          this.terminal.print(`\n[Input Required] ${meta}: `);
          this.terminal.resetAttrs();
          
          const input = await this.terminal.readLine({ echo: true });
          if (!input) {
            return done({ error: 'Input cancelled by user.' });
          }
          
          const newUrl = requestUrl + '?' + encodeURIComponent(input);
          if (DEBUG) this.log(`[GEMINI DEBUG] Submitting input to: ${newUrl}`);
          done(await this._fetchGemini(newUrl, redirectCount));
          
        } else if (status.startsWith('2')) {
          // 2x: Success
          done({ status, meta, body });
          
        } else if (status.startsWith('3')) {
          // 3x: Redirect
          try {
            const nextUrl = new URL(meta, requestUrl).href;
            if (DEBUG) this.log(`[GEMINI DEBUG] Redirecting to: ${nextUrl}`);
            done(await this._fetchGemini(nextUrl, redirectCount + 1));
          } catch (e) {
            done({ error: `Invalid redirect URL: ${meta}` });
          }
          
        } else {
          // 4x, 5x, 6x: Errors
          done({ error: `Server returned status ${status}: ${meta}` });
        }
      });

      client.on('error', (err) => {
        if (DEBUG) this.log(`[GEMINI DEBUG] Socket Error: ${err.message}`);
        done({ error: `Connection error: ${err.message}` });
      });

      client.on('timeout', () => {
        if (DEBUG) this.log(`[GEMINI DEBUG] Connection timeout after 10 seconds.`);
        client.destroy();
        done({ error: 'Connection timed out.' });
      });
    });
  }

  // --- Core Application Views ---

  async _navigate(url) {
    const res = await this._fetchGemini(url);

    if (res.error) {
      this.terminal.setColor(Color.LIGHT_RED, Color.BLACK);
      this.terminal.println(`\nError: ${res.error}`);
      this.terminal.resetAttrs();
      
      this.terminal.setColor(Color.BRIGHT_GREEN, Color.BLACK);
      this.terminal.print('\n[Enter] to go back... ');
      this.terminal.resetAttrs();
      await this.terminal.readLine({ echo: true });
      return 'back';
    }

    const mimeType = res.meta.split(';')[0].trim().toLowerCase() || 'text/gemini';
    const textBody = res.body.toString('utf8').replace(/\r/g, '');

    if (mimeType === 'text/gemini') {
      const parsed = this._parseGemtext(textBody, url);
      return await this._showDocument(url, parsed);
    } else if (mimeType.startsWith('text/')) {
      const parsed = this._parsePlaintext(textBody);
      return await this._showDocument(url, parsed);
    } else {
      this.terminal.setColor(Color.LIGHT_RED, Color.BLACK);
      this.terminal.println(`\nCannot display file of type: ${res.meta}`);
      this.terminal.println('Binary and media downloads are unsupported in the terminal.');
      this.terminal.resetAttrs();
      
      this.terminal.setColor(Color.BRIGHT_GREEN, Color.BLACK);
      this.terminal.print('\n[Enter] to go back... ');
      this.terminal.resetAttrs();
      await this.terminal.readLine({ echo: true });
      return 'back';
    }
  }

  async _showDocument(url, parsedDoc) {
    const { lines, links } = parsedDoc;
    const CHUNK_SIZE = 19; // Safe margin for prompts to stay on screen
    
    let isHome = url === SYNTHDOOR_HOME_URL;
    let title = isHome ? 'Home' : url;

    let i = 0;
    while (i < lines.length || lines.length === 0) {
      if (i === 0) {
        this.terminal.setColor(Color.BRIGHT_MAGENTA, Color.BLACK);
        this.terminal.println(`\n=== ${title} ===`);
        this.terminal.resetAttrs();
      }

      // Render up to CHUNK_SIZE lines
      let rendered = 0;
      for (let j = 0; j < CHUNK_SIZE && (i + j) < lines.length; j++) {
        const l = lines[i + j];
        this._renderLine(l);
        rendered++;
      }
      i += rendered;

      // Ensure we display at least one prompt if the document was totally empty
      if (lines.length === 0) {
        this.terminal.setColor(Color.DARK_GRAY, Color.BLACK);
        this.terminal.println('(Empty document)');
        this.terminal.resetAttrs();
        i = 1; // Break the while loop naturally
      }

      const isEnd = i >= lines.length;
      
      this.terminal.setColor(Color.BRIGHT_YELLOW, Color.BLACK);
      let prompt = '\n';
      if (isEnd) prompt += '--- End of Document ---\n';
      
      prompt += 'Command (';
      if (!isEnd) prompt += '[Enter] next, ';
      prompt += '# link, [b]ack, [u]rl, [q]uit): ';
      
      this.terminal.print(prompt);
      this.terminal.resetAttrs();

      const input = await this.terminal.readLine({ echo: true });
      const val = input.trim().toLowerCase();

      if (val === 'q') return 'quit';
      if (val === 'b') return isHome ? 'stay' : 'back';
      if (val === 'u') {
         const customTarget = await this._promptURL();
         if (customTarget) return { type: 'nav', url: customTarget };
         continue; // Re-render prompt if user aborted URL entry
      }

      const num = parseInt(val, 10);
      if (!isNaN(num) && links[num]) {
        return { type: 'nav', url: links[num] };
      }

      if (val !== '') {
        this.terminal.setColor(Color.LIGHT_RED, Color.BLACK);
        this.terminal.println('Invalid selection.');
        this.terminal.resetAttrs();
        // Step back index to re-render the same chunk on error
        i -= rendered; 
      } else if (isEnd && val === '') {
        // Hitting enter at the end of the doc goes back
        return isHome ? 'stay' : 'back';
      }
    }
  }

  _renderLine(l) {
    if (l.type === 'link') {
      this.terminal.setColor(Color.BRIGHT_GREEN, Color.BLACK);
      this.terminal.print(l.prefix);
      this.terminal.setColor(Color.BRIGHT_WHITE, Color.BLACK);
      this.terminal.println(l.text);
    } else if (l.type === 'h1') {
      this.terminal.setColor(Color.BRIGHT_MAGENTA, Color.BLACK);
      this.terminal.println(l.text);
    } else if (l.type === 'h2') {
      this.terminal.setColor(Color.BRIGHT_CYAN, Color.BLACK);
      this.terminal.println(l.text);
    } else if (l.type === 'h3') {
      this.terminal.setColor(Color.CYAN, Color.BLACK);
      this.terminal.println(l.text);
    } else if (l.type === 'quote') {
      this.terminal.setColor(Color.BRIGHT_YELLOW, Color.BLACK);
      this.terminal.println(l.text);
    } else if (l.type === 'list') {
      this.terminal.setColor(Color.BRIGHT_WHITE, Color.BLACK);
      this.terminal.println(l.text);
    } else if (l.type === 'pre') {
      this.terminal.setColor(Color.BLUE, Color.BLACK);
      this.terminal.println(l.text);
    } else {
      this.terminal.setColor(Color.WHITE, Color.BLACK);
      this.terminal.println(l.text);
    }
  }

  // --- Prompts & Parsers ---

  async _promptURL() {
    this.terminal.setColor(Color.BRIGHT_CYAN, Color.BLACK);
    this.terminal.print('\nEnter URL (e.g. geminispace.info): ');
    this.terminal.resetAttrs();
    
    const input = await this.terminal.readLine({ echo: true });
    let val = input.trim();
    if (!val) return null;
    
    if (!val.includes('://')) {
      val = 'gemini://' + val;
    }
    
    return val;
  }

  _parseGemtext(rawText, baseUrl) {
    const rawLines = rawText.split('\n');
    const formattedLines = [];
    const links = {}; 
    let inPre = false;
    let linkCounter = 1;

    for (let line of rawLines) {
      if (line.startsWith('```')) {
        inPre = !inPre;
        continue; // Hide the toggle lines
      }

      if (inPre) {
        // Preformatted text bypasses word wrapping
        formattedLines.push({ text: this._cleanText(line).substring(0, 79), type: 'pre' });
        continue;
      }

      if (line.startsWith('=>')) {
        const match = line.slice(2).trim().match(/^(\S+)(?:\s+(.*))?$/);
        if (match) {
          let targetUrl = match[1];
          let desc = match[2] || targetUrl;
          
          try {
            targetUrl = new URL(targetUrl, baseUrl).href;
          } catch(e) {
            // Keep raw if unparseable
          }
          
          links[linkCounter] = targetUrl;
          const prefix = `[${linkCounter.toString().padStart(2, ' ')}] `;
          
          // Truncate description to fit line
          desc = this._cleanText(desc);
          const maxLen = 79 - prefix.length;
          if (desc.length > maxLen) desc = desc.substring(0, maxLen - 3) + '...';

          formattedLines.push({ prefix, text: desc, type: 'link' });
          linkCounter++;
        }
      } else if (line.startsWith('###')) {
        formattedLines.push({ text: this._cleanText(line), type: 'h3' });
      } else if (line.startsWith('##')) {
        formattedLines.push({ text: this._cleanText(line), type: 'h2' });
      } else if (line.startsWith('#')) {
        formattedLines.push({ text: this._cleanText(line), type: 'h1' });
      } else if (line.startsWith('>')) {
        const wrapped = Utils.wordWrap(this._cleanText(line.slice(1).trim()), 77);
        wrapped.forEach(w => formattedLines.push({ text: '> ' + w, type: 'quote' }));
      } else if (line.startsWith('*')) {
        const wrapped = Utils.wordWrap(this._cleanText(line.slice(1).trim()), 77);
        formattedLines.push({ text: '• ' + wrapped[0], type: 'list' });
        for (let j = 1; j < wrapped.length; j++) {
          formattedLines.push({ text: '  ' + wrapped[j], type: 'list' });
        }
      } else {
        if (line.trim() === '') {
          formattedLines.push({ text: '', type: 'text' });
        } else {
          const wrapped = Utils.wordWrap(this._cleanText(line), 79);
          wrapped.forEach(w => formattedLines.push({ text: w, type: 'text' }));
        }
      }
    }
    return { lines: formattedLines, links };
  }

  _parsePlaintext(rawText) {
    const rawLines = rawText.split('\n');
    const formattedLines = [];
    for (let line of rawLines) {
      if (line.trim() === '') {
        formattedLines.push({ text: '', type: 'text' });
      } else {
        const wrapped = Utils.wordWrap(this._cleanText(line), 79);
        wrapped.forEach(w => formattedLines.push({ text: w, type: 'text' }));
      }
    }
    return { lines: formattedLines, links: {} };
  }

  _cleanText(str) {
    if (!str) return '';
    // Strip ANSI escape codes and unprintable control chars that disrupt layouts
    return str.replace(/\x1B\[[0-9;]*[a-zA-Z]/g, '')
              .replace(/[\x00-\x08\x0B\x0C\x0E-\x1F]/g, ''); 
  }

  _exitApp() {
    this.terminal.setColor(Color.BRIGHT_WHITE, Color.BLACK);
    this.terminal.println('\nExiting Gemini Browser...');
    this.terminal.resetAttrs();
  }
}

module.exports = GeminiBrowser;