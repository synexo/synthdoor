'use strict';
const path = require('path');
const net  = require('net');
const tls  = require('tls');

const { GameBase, Screen, Color } = require(
  path.join(__dirname, '..', '..', '..', 'packages', 'engine', 'src', 'index.js')
);
const Utils = require(
  path.join(__dirname, '..', '..', '..', 'packages', 'engine', 'src', 'utils.js')
);

// ─────────────────────────────────────────────────────────────────────────────
//  Constants
// ─────────────────────────────────────────────────────────────────────────────
const PROTOCOL_VERSION = '1.3';
const CLIENT_VERSION   = '100';
const CLIENT_NAME      = 'SynthDoor-MRC';
const CTCP_ROOM        = 'ctcp_echo_channel';
const MSG_MAX          = 140;

// Default MRC host — operator can override via synthdoor.conf [game:mrc-chat]
const DEFAULT_HOST     = 'mrc.bottomlessabyss.net';
const DEFAULT_PORT     = 5001;
const DEFAULT_SSL      = true;

// ─────────────────────────────────────────────────────────────────────────────
//  CP437 / Color helpers
// ─────────────────────────────────────────────────────────────────────────────
// Map Mystic-style pipe codes  |01 … |23  to Color constants
const PIPE_FG = [
  Color.BLACK,        // 00 - not used as fg normally
  Color.BLUE,         // 01
  Color.GREEN,        // 02
  Color.CYAN,         // 03
  Color.RED,          // 04
  Color.MAGENTA,      // 05
  Color.YELLOW,       // 06  (brown)
  Color.WHITE,        // 07  (gray)
  Color.DARK_GRAY,    // 08
  Color.BRIGHT_BLUE,  // 09
  Color.BRIGHT_GREEN, // 10
  Color.BRIGHT_CYAN,  // 11
  Color.BRIGHT_RED,   // 12 (light red)
  Color.BRIGHT_MAGENTA,// 13
  Color.BRIGHT_YELLOW, // 14
  Color.BRIGHT_WHITE,  // 15
];
const PIPE_BG = [
  Color.BLACK,    // 16
  Color.BLUE,     // 17
  Color.GREEN,    // 18
  Color.CYAN,     // 19
  Color.RED,      // 20
  Color.MAGENTA,  // 21
  Color.YELLOW,   // 22
  Color.WHITE,    // 23
];

/** Strip pipe codes from a string, return plain text */
function stripPipe(s) {
  return s.replace(/\|(\d{2})/g, '');
}

/** Visible length of a string (no pipe codes) */
function visLen(s) {
  return stripPipe(s).length;
}

/**
 * Print a pipe-coded string to the terminal in scroll mode.
 */
function printPipe(terminal, str, defaultFg = Color.WHITE, defaultBg = Color.BLACK) {
  let fg = defaultFg;
  let bg = defaultBg;
  terminal.setColor(fg, bg);
  
  let buf = '';
  for (let i = 0; i < str.length; i++) {
    if (str[i] === '|' && i + 2 < str.length) {
      const code = parseInt(str.substring(i + 1, i + 3), 10);
      if (!isNaN(code)) {
        if (buf.length > 0) {
          terminal.write(buf);
          buf = '';
        }
        if (code <= 15) {
          fg = PIPE_FG[code] !== undefined ? PIPE_FG[code] : Color.WHITE;
        } else if (code <= 23) {
          bg = PIPE_BG[code - 16] !== undefined ? PIPE_BG[code - 16] : Color.BLACK;
        }
        terminal.setColor(fg, bg);
        i += 2;
        continue;
      }
    }
    buf += str[i];
  }
  if (buf.length > 0) terminal.write(buf);
  terminal.resetAttrs();
}

// ─────────────────────────────────────────────────────────────────────────────
//  MRC Packet helpers
// ─────────────────────────────────────────────────────────────────────────────
function makePacket(fromUser, fromSite, fromRoom, toUser, msgExt, toRoom, body) {
  return `${fromUser}~${fromSite}~${fromRoom}~${toUser}~${msgExt}~${toRoom}~${body}~\n`;
}

function parsePacket(line) {
  const parts = line.split('~');
  if (parts.length < 7) return null;
  return {
    fromUser : parts[0],
    fromSite : parts[1],
    fromRoom : parts[2],
    toUser   : parts[3],
    msgExt   : parts[4],
    toRoom   : parts[5],
    body     : parts[6],
  };
}

// ─────────────────────────────────────────────────────────────────────────────
//  Word-wrap helper
// ─────────────────────────────────────────────────────────────────────────────
function wordWrap(text, width) {
  const words = text.split(' ');
  const lines = [];
  let line = '';
  for (const word of words) {
    if (line === '') {
      line = word;
    } else if (visLen(line) + 1 + visLen(word) <= width) {
      line += ' ' + word;
    } else {
      lines.push(line);
      line = word;
    }
  }
  if (line) lines.push(line);
  return lines.length ? lines : [''];
}

// ─────────────────────────────────────────────────────────────────────────────
//  MRC-Chat Game
// ─────────────────────────────────────────────────────────────────────────────
class MrcChat extends GameBase {
  static get GAME_NAME()  { return 'mrc-chat'; }
  static get GAME_TITLE() { return 'MRC Chat'; }

  // ── lifecycle ──────────────────────────────────────────────────────────────
  async run() {
    // Config from synthdoor.conf [game:mrc-chat]
    this._host    = (this.config && this.config.host)     || DEFAULT_HOST;
    this._port    = parseInt((this.config && this.config.port) || DEFAULT_PORT, 10);
    this._useSSL  = this.config && this.config.ssl !== undefined
                    ? String(this.config.ssl).toLowerCase() !== 'false'
                    : DEFAULT_SSL;
    this._bbsName = (this.config && this.config.bbs_name) || 'SynthDoor BBS';
    this._bbsWeb  = (this.config && this.config.bbs_web)  || 'NONE';
    this._bbsTel  = (this.config && this.config.bbs_tel)  || 'NONE';
    this._bbsSsh  = (this.config && this.config.bbs_ssh)  || 'NONE';
    this._bbsSys  = (this.config && this.config.bbs_sys)  || 'Sysop';
    this._bbsDsc  = (this.config && this.config.bbs_dsc)  || 'A SynthDoor BBS';

    // State
    this._socket       = null;
    this._connected    = false;
    this._running      = true;
    this._inChat       = false;
    this._room         = 'lobby';
    this._topic        = '';
    this._latency      = 0;
    this._chatterCount = 0;
    this._chatters     = [];
    this._lastDMFrom   = '';
    this._mentions     = [];   // array of plain/coded text mentions
    this._inputBuf     = '';
    this._inputMasking = false;
    this._pendingLines = [];   // lines queued from network thread
    this._partialPacket = '';
    this._nick         = this.username || 'guest';
    this._fromSite     = this._bbsName.replace(/[~\s]/g, '_').substring(0, 30);
    this._displayNick  = this._nick;  // may be updated by USERNICK
    this._twits        = new Set();

    // Enable Scroll Mode
    this.screen.setMode(Screen.SCROLL);

    await this._showSplash();
    if (!this._running) return;

    await this._connectAndChat();
  }

  async onDisconnect() {
    this._running = false;
    this._inChat  = false;
    if (this._socket) {
      try { this._socket.destroy(); } catch (_) {}
      this._socket = null;
    }
  }

  // ── splash / connect screen ───────────────────────────────────────────────
  async _showSplash() {
    this.terminal.clearScreen();
    this.terminal.println('');
    this.terminal.setColor(Color.BRIGHT_CYAN, Color.BLACK);
    this.terminal.println('  ███╗   ███╗██████╗  ██████╗');
    this.terminal.println('  ████╗ ████║██╔══██╗██╔════╝');
    this.terminal.println('  ██╔████╔██║██████╔╝██║     ');
    this.terminal.println('  ██║╚██╔╝██║██╔══██╗██║     ');
    this.terminal.println('  ██║ ╚═╝ ██║██║  ██║╚██████╗');
    this.terminal.println('  ╚═╝     ╚═╝╚═╝  ╚═╝ ╚═════╝');
    this.terminal.println('');
    this.terminal.setColor(Color.CYAN, Color.BLACK);
    this.terminal.println('  Multi-Relay Chat for SynthDoor');
    this.terminal.println('');
    
    this.terminal.setColor(Color.DARK_GRAY, Color.BLACK);
    this.terminal.println('  ────────────────────────────────────────');
    this.terminal.setColor(Color.WHITE, Color.BLACK);
    this.terminal.println(`  Host   : ${this._host}`);
    this.terminal.println(`  Port   : ${this._port}`);
    this.terminal.println(`  SSL    : ${this._useSSL ? 'Yes' : 'No'}`);
    this.terminal.println(`  Nick   : ${this._nick}`);
    this.terminal.println(`  BBS    : ${this._bbsName}`);
    this.terminal.setColor(Color.DARK_GRAY, Color.BLACK);
    this.terminal.println('  ────────────────────────────────────────');
    this.terminal.println('');
    
    this.terminal.setColor(Color.BRIGHT_YELLOW, Color.BLACK);
    this.terminal.print('  Press [ENTER] to Connect or [Q] to Quit > ');

    this.input.start();
    const action = await this.input.waitFor('CONFIRM', 'QUIT');
    this.input.stop();

    if (action === 'QUIT') {
      this._running = false;
    }
    this.terminal.println('');
    this.terminal.println('');
  }

  // ── TCP / TLS connection ──────────────────────────────────────────────────
  async _connectAndChat() {
    this.terminal.setColor(Color.CYAN, Color.BLACK);
    this.terminal.print(`Establishing connection to ${this._host}... `);

    try {
      await this._openSocket();
      this.terminal.setColor(Color.BRIGHT_GREEN, Color.BLACK);
      this.terminal.println('Connected!');
    } catch (err) {
      this.terminal.setColor(Color.BRIGHT_RED, Color.BLACK);
      this.terminal.println('Failed!');
      this._showError(`Connection failed: ${err.message}`);
      await this._sleep(3000);
      return;
    }

    // Now enter the main chat UI
    await this._runChat();
  }

  _openSocket() {
    return new Promise((resolve, reject) => {
      const opts = { host: this._host, port: this._port };

      const onConnect = () => {
        this._connected = true;
        this._setupSocketHandlers();
        resolve();
      };

      if (this._useSSL) {
        this._socket = tls.connect({ ...opts, rejectUnauthorized: false }, onConnect);
      } else {
        this._socket = net.connect(opts, onConnect);
      }

      this._socket.once('error', reject);
      this._socket.setTimeout(15000, () => reject(new Error('Connection timed out')));
    });
  }

  _setupSocketHandlers() {
    this._socket.setTimeout(0);
    this._socket.setEncoding('utf8');

    this._socket.on('data', (chunk) => {
      // Buffer partial lines
      const data = this._partialPacket + chunk;
      const lines = data.split('\n');
      this._partialPacket = lines.pop(); // last element (may be empty or partial)
      for (const line of lines) {
        if (line.trim()) this._pendingLines.push(line.trim());
      }
    });

    this._socket.on('close', () => {
      this._connected = false;
      this._pendingLines.push('__DISCONNECTED__');
    });

    this._socket.on('error', (err) => {
      this._connected = false;
      this._pendingLines.push(`__ERROR__:${err.message}`);
    });
  }

  _send(data) {
    if (this._connected && this._socket) {
      try { this._socket.write(data); } catch (_) {}
    }
  }

  _sendPacket(fromUser, fromSite, fromRoom, toUser, msgExt, toRoom, body) {
    this._send(makePacket(fromUser, fromSite, fromRoom, toUser, msgExt, toRoom, body));
  }

  _sendCmd(cmd, arg) {
    const body = arg ? `${cmd}:${arg}` : cmd;
    this._sendPacket(this._displayNick, this._fromSite, this._room, 'SERVER', '', '', body);
  }

  _sendMsg(toUser, msgExt, toRoom, body) {
    this._sendPacket(this._displayNick, this._fromSite, this._room, toUser, msgExt, toRoom, body);
  }

  // Send the MRC handshake
  _sendHandshake() {
    const hs = `${this._bbsName}~${CLIENT_NAME}/SynthDoor.Node/${PROTOCOL_VERSION}.${CLIENT_VERSION}`;
    this._send(hs);
  }

  _sendInfoPackets() {
    this._sendCmd('INFOWEB', this._bbsWeb);
    this._sendCmd('INFOTEL', this._bbsTel);
    this._sendCmd('INFOSSH', this._bbsSsh);
    this._sendCmd('INFOSYS', this._bbsSys);
    this._sendCmd('INFODSC', this._bbsDsc);
    this._sendCmd('IMALIVE', this._bbsName);
    this._sendCmd('CAPABILITIES', 'MCI CTCP');
  }

  // ── Main chat UI ──────────────────────────────────────────────────────────
  async _runChat() {
    this._inChat = true;
    
    // Draw initial input row
    this.terminal.println('');
    this._redrawInput();

    // Send handshake immediately
    this._sendHandshake();

    this.input.start();
    this._setupInputHandlers();

    let lastPing = Date.now();

    while (this._inChat && this._running) {
      // Process any incoming packets
      while (this._pendingLines.length > 0) {
        const line = this._pendingLines.shift();
        this._handleIncoming(line);
      }

      // Periodic IMALIVE / ping response
      const now = Date.now();
      if (now - lastPing > 60000) {
        this._sendCmd('IMALIVE', 'ACTIVE');
        this._sendCmd('STATS', '');
        lastPing = now;
      }

      await this._sleep(50);
    }

    this.input.stop();
    this._removeInputHandlers();

    // Disconnect
    if (this._connected) {
      this._sendMsg('NOTME', '', '', '|08- ' + this._displayNick + ' |04has left.');
      this._sendMsg('SERVER', '', '', 'LOGOFF');
      await this._sleep(200);
      try { this._socket.destroy(); } catch (_) {}
    }

    // Show goodbye
    this.terminal.println('');
    this.terminal.setColor(Color.BRIGHT_YELLOW, Color.BLACK);
    this.terminal.println('Disconnected from MRC. Thanks for chatting!');
    this.terminal.setColor(Color.CYAN, Color.BLACK);
    this.terminal.print('Press any key to return... ');
    await this.terminal.waitKey();
  }

  // ── Input drawing ─────────────────────────────────────────────────────────
  /**
   * Overwrite the current bottom line to cleanly display the prompt + input buffer.
   * Uses raw ANSI to ensure the cursor returns to column 1 and Erases to EOL.
   */
  _redrawInput() {
    // Return to Col 1 (\r) and clear line to the right (\x1b[K)
    this.terminal.writeRaw('\r\x1b[K');
    
    this.terminal.setColor(Color.BRIGHT_GREEN, Color.BLACK);
    this.terminal.print(`[${this._room}]> `);
    
    this.terminal.setColor(Color.WHITE, Color.BLACK);
    const display = this._inputMasking
      ? '*'.repeat(this._inputBuf.length)
      : this._inputBuf;
      
    this.terminal.print(display);
  }

  // ── Input handling ────────────────────────────────────────────────────────
  _setupInputHandlers() {
    this._onAction = (action) => {
      switch (action) {
        case 'CONFIRM':
          this._submitInput();
          break;
        case 'CANCEL':
          // ESC = clear input
          this._inputBuf = '';
          this._inputMasking = false;
          this._redrawInput();
          break;
        case 'TAB':
          this._tabComplete();
          break;
      }
    };

    this._onKey = (key) => {
      // Backspace
      if (key === '\x7f' || key === '\b') {
        if (this._inputBuf.length > 0) {
          this._inputBuf = this._inputBuf.slice(0, -1);
          this._redrawInput();
        }
        return;
      }
      // Printable ASCII
      if (key.length === 1 && key >= ' ' && key <= '~') {
        if (this._inputBuf.length < MSG_MAX) {
          this._inputBuf += key;
          // Check for masking triggers
          const low = this._inputBuf.toLowerCase();
          this._inputMasking = low.startsWith('/identify ') || low.startsWith('/roompass ');
          this._redrawInput();
        }
      }
    };

    this.input.on('action', this._onAction);
    this.terminal.on('key', this._onKey);
  }

  _removeInputHandlers() {
    if (this._onAction) this.input.removeListener('action', this._onAction);
    if (this._onKey)    this.terminal.removeListener('key', this._onKey);
  }

  _tabComplete() {
    if (!this._inputBuf || this._chatters.length === 0) return;
    // Find last word
    const lastSpace = this._inputBuf.lastIndexOf(' ');
    const prefix = this._inputBuf.substring(lastSpace + 1).toLowerCase();
    if (!prefix) return;
    const match = this._chatters.find(c =>
      c.toLowerCase().startsWith(prefix) &&
      c.toLowerCase() !== this._displayNick.toLowerCase()
    );
    if (match) {
      this._inputBuf = this._inputBuf.substring(0, lastSpace + 1) + match;
      this._redrawInput();
    }
  }

  _submitInput() {
    const text = this._inputBuf.trim();
    this._inputBuf = '';
    this._inputMasking = false;
    
    // Clear the line immediately so local echoes and network delays look clean
    this.terminal.writeRaw('\r\x1b[K');
    
    if (!text) {
      this._redrawInput();
      return;
    }

    if (text.startsWith('/')) {
      this._processCommand(text);
    } else {
      // Send chat message
      const body = `|15${this._displayNick}|07 |07${text}`;
      this._sendMsg('', '', this._room, body);
      // Echo locally
      this._addLine(`|08[me] |07${text}`, false);
    }
  }

  _processCommand(text) {
    const spaceIdx = text.indexOf(' ');
    const cmd    = spaceIdx > 0 ? text.substring(1, spaceIdx).toLowerCase() : text.substring(1).toLowerCase();
    const params = spaceIdx > 0 ? text.substring(spaceIdx + 1) : '';

    switch (cmd) {
      case 'quit': case 'q':
        this._inChat = false;
        break;

      case 'join': case 'j': {
        const newRoom = params.replace('#', '').replace(/\s+/g, '_').replace(/\|.{2}/g, '');
        if (newRoom) {
          const oldRoom = this._room;
          this._sendCmd(`NEWROOM:${oldRoom}:`, newRoom);
          this._room = newRoom;
          this._addLine(`|14* Joining #${newRoom}...`, false);
          this._sendCmd('USERLIST', '');
        } else {
           this._redrawInput();
        }
        break;
      }

      case 'msg': case 't': {
        const parts = params.split(' ');
        const to = parts[0];
        const msg = parts.slice(1).join(' ');
        if (to && msg) {
          const body = `|15* |08(|15${this._displayNick}|08/|14DirectMsg|08) |07${msg}`;
          this._sendMsg(to, '', '', body);
          this._addLine(`|15* |08(|14DirectMsg|08->|15${to}|08) |07${msg}`, false);
        } else {
          this._redrawInput();
        }
        break;
      }

      case 'r': {
        if (this._lastDMFrom && params) {
          const body = `|15* |08(|15${this._displayNick}|08/|14DirectMsg|08) |07${params}`;
          this._sendMsg(this._lastDMFrom, '', '', body);
          this._addLine(`|15* |08(|14DirectMsg|08->|15${this._lastDMFrom}|08) |07${params}`, false);
        } else {
          this._redrawInput();
        }
        break;
      }

      case 'me':
        if (params) {
          const body = `|15* |13${this._displayNick} ${params}`;
          this._sendMsg('', '', this._room, body);
        }
        this._redrawInput();
        break;

      case 'topic':
        if (params) {
          this._sendCmd(`NEWTOPIC:${this._room}:`, params);
        }
        this._redrawInput();
        break;

      case 'rooms': case 'list':
        this._sendCmd('list', '');
        this._redrawInput();
        break;

      case 'users': case 'whoon':
        this._sendCmd(cmd, '');
        this._sendCmd('USERLIST', '');
        this._redrawInput();
        break;

      case 'motd':
        this._sendCmd('motd', '');
        this._redrawInput();
        break;

      case 'twit': {
        const tparts = params.split(' ');
        const action = tparts[0] ? tparts[0].toLowerCase() : '';
        const who    = tparts[1] || '';
        if (action === 'add' && who) {
          this._twits.add(who.toLowerCase());
          this._addLine(`|15* |14${who} |07added to twit list.`, false);
        } else if (action === 'del' && who) {
          this._twits.delete(who.toLowerCase());
          this._addLine(`|15* |14${who} |07removed from twit list.`, false);
        } else if (action === 'list') {
          if (this._twits.size === 0) {
            this._addLine('|07Twit list is empty.', false);
          } else {
            for (const t of this._twits) this._addLine(`|08* |07${t}`, false);
          }
        } else if (action === 'clear') {
          this._twits.clear();
          this._addLine('|15* |07Twit list cleared.', false);
        } else {
          this._redrawInput();
        }
        break;
      }

      case 'mentions':
        if (this._mentions.length === 0) {
          this._addLine('|07No recent mentions.', false);
        } else {
          this._addLine('|14--- Recent Mentions ---', false);
          for (const m of this._mentions) {
            this._addLine(m, false);
          }
          this._addLine('|14-----------------------', false);
        }
        break;

      case 'ctcp': {
        const cparts = params.split(' ');
        const target = cparts[0];
        const ctcpcmd = (cparts[1] || '').toUpperCase();
        if (target && ctcpcmd) {
          const ctcpData = `${ctcpcmd} ${this._displayNick}`;
          this._sendPacket(this._displayNick, this._fromSite, CTCP_ROOM,
            target, '', CTCP_ROOM, `[CTCP] ${ctcpData}`);
        }
        this._redrawInput();
        break;
      }

      case 'help':
        this._showHelp();
        break;

      default:
        // Pass unknown commands straight to server
        this._sendCmd(cmd.toUpperCase(), params);
        this._redrawInput();
        break;
    }
  }

  // ── Incoming packet handler ───────────────────────────────────────────────
  _handleIncoming(line) {
    if (line === '__DISCONNECTED__') {
      this._addLine('|12* Connection closed by server.', true);
      this._inChat = false;
      return;
    }
    if (line.startsWith('__ERROR__:')) {
      this._addLine(`|12* Network error: ${line.substring(10)}`, true);
      this._inChat = false;
      return;
    }

    if (!line.includes('~')) return;

    const pkt = parsePacket(line);
    if (!pkt) return;

    const { fromUser, fromRoom, toUser, toRoom, body } = pkt;

    // Strip control characters from body
    const cleanBody = body.replace(/[\x01-\x06\x08-\x1f]/g, '_');

    // SERVER messages
    if (fromUser === 'SERVER') {
      if (toRoom === this._room || !toRoom) {
        this._handleServerMessage(cleanBody, toUser);
      }
      // NOTME server messages for our room
      if (toUser === 'NOTME') {
        if ((!fromRoom || fromRoom === this._room) && (!toRoom || toRoom === this._room)) {
          this._addLine(cleanBody, false);
        }
      }
      return;
    }

    // CTCP
    if (toRoom === CTCP_ROOM && fromRoom === CTCP_ROOM) {
      this._handleCtcp(cleanBody, toUser, fromUser);
      return;
    }

    // NOTME (room broadcasts from other users)
    if (toUser === 'NOTME') {
      if ((!fromRoom || fromRoom === this._room) && (!toRoom || toRoom === this._room)) {
        this._addLine(cleanBody, false);
        this._sendCmd('USERLIST', '');
      }
      return;
    }

    // Regular chat / DM
    const forMe = (!toUser || toUser.toLowerCase() === this._displayNick.toLowerCase());
    const forRoom = (!toRoom || toRoom === this._room);
    if (forMe && forRoom) {
      // Twit filter
      if (this._twits.has(fromUser.toLowerCase())) return;

      // DM?
      if (toUser && fromUser) {
        this._addLine(cleanBody, false);
        this._lastDMFrom = fromUser;
        return;
      }

      // Mention check
      const mentioned = fromUser.toLowerCase() !== this._displayNick.toLowerCase() &&
        cleanBody.toLowerCase().includes(this._displayNick.toLowerCase());

      this._addLine(cleanBody, mentioned);
    }
  }

  _handleServerMessage(body, toUser) {
    const colonIdx = body.indexOf(':');
    const cmd    = colonIdx >= 0 ? body.substring(0, colonIdx) : body;
    const params = colonIdx >= 0 ? body.substring(colonIdx + 1) : '';

    switch (cmd) {
      case 'HELLO':
        this._sendInfoPackets();
        this._sendCmd('motd', '');
        this._sendCmd('NEWROOM::', this._room);
        this._sendCmd('USERLIST', '');
        this._addLine(`|10* Connected to MRC! Type |15/help |10for commands.`, false);
        break;

      case 'ROOMTOPIC': {
        const newTopic = params.substring(this._room.length + 1);
        if (this._topic !== newTopic) {
          this._topic = newTopic;
          this._addLine(`|11* Topic for #${this._room}: |14${this._topic}`, false);
        }
        break;
      }

      case 'USERROOM':
        if (this._room !== params) {
          this._room = params;
          this._addLine(`|11* You are now in #${this._room}`, false);
        }
        break;

      case 'USERNICK':
        this._displayNick = params;
        this._addLine(`|15* |08(|14Notice|08) |07Server updated your nick to |15${params}|07.`, true);
        break;

      case 'USERLIST': {
        const list = params.split(',').map(s => s.trim()).filter(Boolean);
        this._chatters     = list;
        this._chatterCount = list.length;
        // Kept silent in SCROLL mode so it doesn't spam unless they use /users (whoon response)
        break;
      }

      case 'LATENCY':
        this._latency = params;
        break;

      case 'TERMINATE':
        this._addLine(`|12* SERVER: ${params}`, true);
        this._inChat = false;
        break;

      case 'BANNER': case 'NOTIFY':
        this._addLine(`|14* |13<|15!|13> |15${params}`, false);
        break;

      case 'STATS':
        // We got a stats response — just ignore
        break;

      default:
        // Display informational server messages if addressed to us or everyone
        if (!toUser || toUser.toLowerCase() === this._displayNick.toLowerCase()) {
          this._addLine(body, false);
        }
        break;
    }
  }

  _handleCtcp(body, toUser, fromUser) {
    if (!body.startsWith('[CTCP] ')) return;
    if (toUser && toUser.toLowerCase() !== this._displayNick.toLowerCase()) return;

    const payload = body.substring(7);
    const parts   = payload.split(' ');
    const ctcpCmd = parts[0];

    let reply = '';
    switch (ctcpCmd) {
      case 'VERSION':
        reply = `VERSION ${CLIENT_NAME} v${PROTOCOL_VERSION}.${CLIENT_VERSION} [SynthDoor]`;
        break;
      case 'TIME':
        reply = `TIME ${new Date().toLocaleString()}`;
        break;
      case 'PING':
        reply = `PING ${parts.slice(1).join(' ')}`;
        break;
      case 'CLIENTINFO':
        reply = 'CLIENTINFO VERSION TIME PING CLIENTINFO';
        break;
      default:
        reply = `Unsupported CTCP: ${ctcpCmd}`;
        break;
    }
    this._sendPacket(this._displayNick, this._fromSite, CTCP_ROOM,
      fromUser, '', CTCP_ROOM, `[CTCP-REPLY] ${reply}`);
  }

  // ── Scroll Mode Output ────────────────────────────────────────────────────
  /**
   * Print a line to the terminal.
   * Interrupts the active input line, prints the chat line, and repaints input.
   */
  _addLine(text, mention) {
    const lines = wordWrap(text, 78);
    
    // Erase the current input line first
    this.terminal.writeRaw('\r\x1b[K');

    for (const l of lines) {
      if (mention) {
        this.terminal.setColor(Color.BRIGHT_YELLOW, Color.BLACK);
        this.terminal.print('\xfe ');
      }
      printPipe(this.terminal, l);
      this.terminal.println('');
    }
    
    if (mention) {
      this._mentions.push(text);
      if (this._mentions.length > 50) this._mentions.shift();
    }

    // Immediately restore input line
    if (this._inChat) {
      this._redrawInput();
    }
  }

  // ── Help overlay ──────────────────────────────────────────────────────────
  _showHelp() {
    const helpLines = [
      '|15/join |11#room      |07- Join a chat room',
      '|15/quit             |07- Leave MRC chat',
      '|15/msg |11user text   |07- Send a direct message',
      '|15/r |11text         |07- Reply to last DM',
      '|15/me |11action      |07- Send an action',
      '|15/topic |11text     |07- Change room topic',
      '|15/rooms            |07- List rooms',
      '|15/users            |07- List users in room',
      '|15/motd             |07- Show message of the day',
      '|15/twit add|11 user  |07- Add user to twit filter',
      '|15/twit del|11 user  |07- Remove from twit filter',
      '|15/twit list        |07- Show twit list',
      '|15/ctcp |11user cmd  |07- Send CTCP command',
      '|15/mentions         |07- Show recent mentions',
      '|14TAB               |07- Nickname autocomplete',
      '|14ESC               |07- Clear input line',
    ];
    for (const l of helpLines) this._addLine(l, false);
  }

  // ── Error display ─────────────────────────────────────────────────────────
  _showError(msg) {
    this.terminal.println('');
    this.terminal.setColor(Color.BRIGHT_RED, Color.BLACK);
    this.terminal.println(`MRC CHAT — Error: ${msg}`);
  }

  // ── Utility ───────────────────────────────────────────────────────────────
  _sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
}

module.exports = MrcChat;